---
/**
 * Footer — brand, nav, real contact details, book CTA.
 */
const year = new Date().getFullYear();
const PHONE_DISPLAY = '+91 98180 83992';
const PHONE_INTL = '+919818083992';
const EMAIL = 'thehiddenoak@gmail.com';

const links = [
  { href: '/the-banya', label: 'The Banya' },
  { href: '/services', label: 'Services' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/book', label: 'Book Now' },
  { href: '/location', label: 'Location' },
];
---

<footer class="site-footer">
  <div class="site-footer__glow" aria-hidden="true"></div>
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <a href="/" class="brand-mark">Hidden Oak</a>
      <p class="brand-tagline">
        A traditional Russian banya on the Goan coast — heat, cold, and quiet
        among the palms of Arambol.
      </p>
      <span class="deco-motif" style="color: var(--clay-terracotta); margin: var(--space-3) 0 0; opacity: 0.55;" aria-hidden="true"></span>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <p class="eyebrow">Explore</p>
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__contact">
      <p class="eyebrow">Visit</p>
      <p class="site-footer__addr">
        H. No. 613/2, Madhalawada<br />
        Arambol, Goa 403524
      </p>
      <p class="site-footer__hours">Open daily · 6 PM – midnight</p>
      <ul class="site-footer__channels">
        <li>
          <a href={`tel:${PHONE_INTL}`}>{PHONE_DISPLAY}</a>
        </li>
        <li>
          <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
        </li>
        <li>
          <a
            href={`https://wa.me/${PHONE_INTL.replace('+', '')}?text=${encodeURIComponent("Hi Hidden Oak, I'd like to book a banya session.")}`}
            target="_blank"
            rel="noopener"
          >
            WhatsApp us
          </a>
        </li>
      </ul>
      <p class="site-footer__book">
        <a href="/book">Book a session →</a>
      </p>
    </div>
  </div>

  <div class="site-footer__bar container">
    <p>© {year} Hidden Oak Banya · Arambol, Goa</p>
    <p class="built">Heat · Cold · Rest</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background:
      linear-gradient(180deg, transparent, rgba(47, 33, 24, 0.5) 20%),
      var(--wood-burnt);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
    overflow: hidden;
  }
  .site-footer__glow {
    position: absolute;
    inset: auto 0 0 0;
    height: 120px;
    background: radial-gradient(ellipse 60% 100% at 50% 100%, rgba(196, 106, 40, 0.12), transparent 70%);
    pointer-events: none;
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: var(--space-6);
    padding-block: var(--space-7) var(--space-6);
    position: relative;
  }
  .brand-mark {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--birch-white);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
  }
  .brand-mark:hover { color: var(--hot-coal-bright); }
  .brand-tagline {
    margin-top: var(--space-3);
    color: var(--color-ink-subtle);
    max-width: 34ch;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .site-footer__nav ul {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .site-footer__nav a {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-soft),
      padding-left var(--duration-fast) var(--ease-soft);
  }
  .site-footer__nav a:hover {
    color: var(--birch-white);
    padding-left: 4px;
  }

  .site-footer__addr,
  .site-footer__hours {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    margin-top: var(--space-1);
  }
  .site-footer__hours {
    color: var(--color-gold);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin-top: var(--space-2);
    letter-spacing: 0.02em;
  }
  .site-footer__channels {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .site-footer__channels a {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink-muted);
  }
  .site-footer__channels a:hover { color: var(--hot-coal-bright); }
  .site-footer__book {
    margin-top: var(--space-3) !important;
  }
  .site-footer__book a {
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
  }

  .site-footer__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    position: relative;
  }
  .built {
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-gold);
    opacity: 0.7;
  }

  @media (max-width: 800px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .site-footer__bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
