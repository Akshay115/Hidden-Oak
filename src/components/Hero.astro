---
/**
 * Hero — full-bleed cinematic landing.
 * Brighter golden-hour treatment, dual heat + ice atmosphere,
 * logo lives in the floating nav over this image (no site header bar).
 */
import CTAButton from './CTAButton.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  video?: string;
  poster?: string;
  image?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  align?: 'left' | 'center';
  compact?: boolean;
  atmosphere?: boolean;
  /** Emphasize ice atmosphere (frost particles, cool grade) */
  ice?: boolean;
  /** Dual heat + ice particles */
  dual?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  video,
  poster,
  image,
  primaryCta = { href: '/book', label: 'Book a Session' },
  secondaryCta,
  align = 'left',
  compact = false,
  atmosphere = true,
  ice = false,
  dual = true,
} = Astro.props;

const bgImage = poster || image;
const hasVideo = Boolean(video);
const showAtm = atmosphere && !bgImage && !hasVideo;
const showIce = ice || dual;
const showHeat = !ice || dual;
---

<section
  class:list={[
    'hero',
    `hero--${align}`,
    {
      'hero--has-video': hasVideo,
      'hero--has-image': Boolean(bgImage),
      'hero--compact': compact,
      'hero--atmosphere': showAtm || Boolean(bgImage),
      'hero--ice': ice && !dual,
      'hero--dual': dual,
    },
  ]}
  data-has-video={hasVideo ? 'true' : 'false'}
>
  <div class="hero__media" aria-hidden="true">
    {
      showAtm && (
        <img
          class="hero__poster hero__poster--atm"
          src="/images/hero/hero-poster.jpg"
          alt=""
          role="presentation"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )
    }
    {
      bgImage && (
        <img
          class="hero__poster"
          src={bgImage}
          alt=""
          role="presentation"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )
    }
    {
      hasVideo && video && (
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={bgImage || undefined}
          tabindex="-1"
        >
          <source src={video} type="video/mp4" />
        </video>
      )
    }
  </div>

  <!-- Golden-hour wash: lifts midtones, keeps edges readable -->
  <div class="hero__grade" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true"></div>

  {
    showHeat && (
      <div class="hero__steam" aria-hidden="true">
        <span class="hero__steam-cloud hero__steam-cloud--a"></span>
        <span class="hero__steam-cloud hero__steam-cloud--b"></span>
        <span class="hero__steam-cloud hero__steam-cloud--c"></span>
      </div>
    )
  }

  {
    showHeat && (
      <div class="ember-field" aria-hidden="true">
        {[14, 30, 48, 66, 82, 90, 38, 58].map((left, i) => (
          <span
            class="ember"
            style={`left:${left}%; bottom:${(i % 4) * 8}%; --ember-dur:${8 + (i % 5)}s; --ember-delay:${i * 1.1}s;`}
          />
        ))}
      </div>
    )
  }

  {
    showIce && (
      <div class="frost-field" aria-hidden="true">
        {[8, 22, 40, 55, 72, 85, 18, 62, 44, 78].map((left, i) => (
          <span
            class="frost"
            style={`left:${left}%; top:${(i % 5) * 12 + 8}%; --frost-dur:${10 + (i % 6)}s; --frost-delay:${i * 0.85}s; --frost-size:${3 + (i % 4)}px;`}
          />
        ))}
      </div>
    )
  }

  <div class="hero__content container">
    {
      dual && !compact && (
        <div class="hero__pillars" data-reveal="fade" aria-hidden="true">
          <span class="hero__pillar hero__pillar--heat">
            <span class="deco-icon deco-icon--sm deco-icon--flame"></span>
            Fire
          </span>
          <span class="hero__pillars-dot"></span>
          <span class="hero__pillar hero__pillar--ice">
            <span class="deco-icon deco-icon--sm deco-icon--snowflake"></span>
            Ice
          </span>
        </div>
      )
    }
    {eyebrow && <p class="eyebrow hero__eyebrow" data-reveal="fade">{eyebrow}</p>}
    <h1 class="hero__title" data-reveal style="--reveal-delay: 60ms">{title}</h1>
    {subtitle && (
      <p class="hero__subtitle" data-reveal style="--reveal-delay: 140ms">
        {subtitle}
      </p>
    )}
    <div class="hero__actions" data-reveal style="--reveal-delay: 220ms">
      <CTAButton href={primaryCta.href} variant="primary" size="lg">{primaryCta.label}</CTAButton>
      {
        secondaryCta && (
          <CTAButton href={secondaryCta.href} variant="ghost" size="lg">
            {secondaryCta.label}
          </CTAButton>
        )
      }
    </div>
  </div>

  {
    !compact && (
      <a href="#main-content" class="hero__scroll" aria-label="Scroll to content">
        <span class="hero__scroll-line" aria-hidden="true"></span>
        <span class="hero__scroll-text">Explore</span>
      </a>
    )
  }

  <script is:inline>
    (function () {
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var hero = document.currentScript && document.currentScript.closest('.hero');
      var video = hero && hero.querySelector('video.hero__video');
      if (!video) return;
      if (prefersReduced) {
        video.pause();
        video.removeAttribute('autoplay');
      }
      window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', function (e) {
        if (e.matches) {
          video.pause();
        } else {
          video.play().catch(function () {});
        }
      });
    })();
  </script>
</section>

<style>
  .hero {
    position: relative;
    background:
      radial-gradient(120% 80% at 50% 20%, rgba(255, 176, 96, 0.22), transparent 58%),
      radial-gradient(80% 60% at 85% 90%, rgba(120, 180, 210, 0.12), transparent 50%),
      #2a1f16;
    min-height: 100svh;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    /* Room for floating nav logo over the image */
    padding-top: var(--header-height);
  }
  .hero--compact {
    min-height: clamp(380px, 56vh, 560px);
    align-items: center;
  }
  .hero--center .hero__content {
    text-align: center;
    align-items: center;
    margin-inline: auto;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero__poster,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }
  /* Brighter — golden hour before sunset */
  .hero__poster,
  .hero__poster--atm {
    filter:
      brightness(1.18)
      contrast(1.06)
      saturate(1.18)
      sepia(0.08);
    animation: hero-ken 32s var(--ease-in-out) infinite alternate;
  }
  .hero--ice .hero__poster {
    filter:
      brightness(1.2)
      contrast(1.05)
      saturate(0.95)
      hue-rotate(8deg);
  }
  @keyframes hero-ken {
    from { transform: scale(1.02); }
    to { transform: scale(1.1); }
  }
  .hero__poster { z-index: 1; }
  .hero__video { z-index: 2; }

  /* Warm lift + subtle cool at edges for dual story */
  .hero__grade {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(ellipse 90% 70% at 40% 55%, rgba(255, 190, 110, 0.18), transparent 65%),
      radial-gradient(ellipse 50% 55% at 88% 70%, rgba(140, 200, 230, 0.14), transparent 60%),
      linear-gradient(180deg, rgba(255, 200, 130, 0.1) 0%, transparent 40%);
    mix-blend-mode: soft-light;
  }

  .hero__steam {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }
  .hero__steam-cloud {
    position: absolute;
    width: 90%;
    height: 75%;
    background-image: var(--img-steam);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    filter: blur(8px);
    opacity: 0.16;
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  .hero__steam-cloud--a {
    top: 0;
    left: -30%;
    animation: steam-drift-a 28s var(--ease-in-out) infinite;
  }
  .hero__steam-cloud--b {
    bottom: -8%;
    right: -35%;
    width: 95%;
    opacity: 0.12;
    animation: steam-drift-b 34s var(--ease-in-out) infinite;
    animation-delay: -12s;
  }
  .hero__steam-cloud--c {
    top: 30%;
    left: 10%;
    width: 70%;
    height: 50%;
    opacity: 0.08;
    animation: steam-drift-a 40s var(--ease-in-out) infinite reverse;
    animation-delay: -6s;
  }
  @keyframes steam-drift-a {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.1; }
    50%  { transform: translate(32vw, 20px) scale(1.1); opacity: 0.22; }
    100% { transform: translate(68vw, 0) scale(1); opacity: 0.1; }
  }
  @keyframes steam-drift-b {
    0%   { transform: translate(0, 0) scale(1.05); opacity: 0.06; }
    50%  { transform: translate(-30vw, -16px) scale(1.14); opacity: 0.16; }
    100% { transform: translate(-65vw, 0) scale(1.05); opacity: 0.06; }
  }

  .hero .ember-field,
  .hero .frost-field { z-index: 3; }

  .frost-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .frost {
    position: absolute;
    width: var(--frost-size, 4px);
    height: var(--frost-size, 4px);
    border-radius: 50%;
    background: radial-gradient(circle, #e8f4ff 0%, #9ec8e0 60%, transparent 100%);
    box-shadow: 0 0 8px rgba(160, 210, 240, 0.55), 0 0 16px rgba(120, 180, 220, 0.25);
    opacity: 0;
    animation: frost-drift var(--frost-dur, 11s) var(--ease-in-out) infinite;
    animation-delay: var(--frost-delay, 0s);
  }
  @keyframes frost-drift {
    0%   { transform: translateY(-10px) translateX(0) scale(0.5); opacity: 0; }
    15%  { opacity: 0.85; }
    70%  { opacity: 0.35; }
    100% { transform: translateY(55vh) translateX(-18px) scale(1.1); opacity: 0; }
  }

  /* Lighter overlays so the photo reads as golden-hour */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(28, 20, 14, 0.28) 0%,
        rgba(28, 20, 14, 0.08) 32%,
        rgba(28, 20, 14, 0.28) 62%,
        rgba(28, 20, 14, 0.72) 100%
      ),
      radial-gradient(120% 100% at 50% 45%, transparent 40%, rgba(28, 20, 14, 0.28) 100%);
  }
  .hero--left .hero__overlay {
    background:
      linear-gradient(
        180deg,
        rgba(28, 20, 14, 0.32) 0%,
        rgba(28, 20, 14, 0.06) 35%,
        rgba(28, 20, 14, 0.35) 68%,
        rgba(28, 20, 14, 0.78) 100%
      ),
      linear-gradient(95deg, rgba(28, 20, 14, 0.55) 0%, rgba(28, 20, 14, 0.22) 38%, transparent 70%);
  }
  .hero--ice .hero__overlay {
    background:
      linear-gradient(
        180deg,
        rgba(18, 32, 42, 0.35) 0%,
        rgba(18, 32, 42, 0.1) 40%,
        rgba(18, 32, 42, 0.55) 100%
      );
  }

  .hero__content {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-7) var(--space-8);
    align-items: flex-start;
    max-width: min(720px, 94vw);
  }
  .hero--compact .hero__content {
    padding-block: var(--space-6) var(--space-6);
    max-width: min(var(--container-narrow), 94vw);
  }

  .hero__pillars {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 248, 239, 0.1);
    border: 1px solid rgba(255, 248, 239, 0.22);
    backdrop-filter: blur(10px);
    margin-bottom: 0.25rem;
  }
  .hero__pillar {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: #fff8ef;
  }
  .hero__pillar--heat { color: #ffc9a0; }
  .hero__pillar--ice { color: #c5e4f5; }
  .hero__pillars-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 248, 239, 0.45);
  }

  .hero__title {
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    max-width: 15ch;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0, 0, 0, 0.4);
    color: #fff8ef;
    background: none;
  }
  .hero__subtitle {
    font-size: var(--text-md);
    color: rgba(255, 250, 245, 0.94);
    max-width: 46ch;
    line-height: var(--leading-loose);
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45), 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .hero--center .hero__actions { justify-content: center; }

  .hero :global(.cta--ghost) {
    color: #ffffff !important;
    border-color: rgba(255, 255, 255, 0.5) !important;
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(8px);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }
  .hero :global(.cta--ghost:hover) {
    color: #ffffff !important;
    border-color: #9ec8e0 !important;
    background: rgba(140, 200, 230, 0.18) !important;
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: rgba(255, 248, 239, 0.75);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    transition: opacity var(--duration-fast) var(--ease-soft),
      color var(--duration-fast) var(--ease-soft);
  }
  .hero__scroll:hover {
    color: #ffc9a0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, #ffc9a0, transparent);
    animation: scroll-pulse 2.2s var(--ease-in-out) infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.6); opacity: 0.4; transform-origin: top; }
    50% { transform: scaleY(1); opacity: 1; transform-origin: top; }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 92svh;
      align-items: flex-end;
    }
    .hero--compact {
      min-height: clamp(320px, 48vh, 420px);
    }
    .hero__title {
      font-size: var(--text-3xl);
      max-width: 12ch;
    }
    .hero__subtitle {
      font-size: var(--text-sm);
    }
    .hero__content {
      padding-block: var(--space-5) var(--space-7);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero__poster,
    .hero__poster--atm { animation: none; }
    .frost-field,
    .ember-field,
    .hero__steam { display: none; }
  }
</style>
