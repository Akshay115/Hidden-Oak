---
/**
 * Hero — full-bleed cinematic landing block with steam, embers, optional media.
 */
import CTAButton from './CTAButton.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  video?: string;
  poster?: string;
  image?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  align?: 'left' | 'center';
  /** Compact height for inner pages */
  compact?: boolean;
  /** Show ambient atmosphere image even without poster */
  atmosphere?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  video,
  poster,
  image,
  primaryCta = { href: '/book', label: 'Book a Session' },
  secondaryCta,
  align = 'left',
  compact = false,
  atmosphere = true,
} = Astro.props;

const bgImage = poster || image;
const hasVideo = Boolean(video);
const showAtm = atmosphere && !bgImage && !hasVideo;
---

<section
  class:list={[
    'hero',
    `hero--${align}`,
    {
      'hero--has-video': hasVideo,
      'hero--has-image': Boolean(bgImage),
      'hero--compact': compact,
      'hero--atmosphere': showAtm || Boolean(bgImage),
    },
  ]}
  data-has-video={hasVideo ? 'true' : 'false'}
>
  <div class="hero__media" aria-hidden="true">
    {
      showAtm && (
        <img
          class="hero__poster hero__poster--atm"
          src="/images/generated/hero-atmosphere.jpg"
          alt=""
          role="presentation"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )
    }
    {
      bgImage && (
        <img
          class="hero__poster"
          src={bgImage}
          alt=""
          role="presentation"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )
    }
    {
      hasVideo && video && (
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={bgImage || undefined}
          tabindex="-1"
        >
          <source src={video} type="video/mp4" />
        </video>
      )
    }
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__steam" aria-hidden="true">
    <span class="hero__steam-cloud hero__steam-cloud--a"></span>
    <span class="hero__steam-cloud hero__steam-cloud--b"></span>
    <span class="hero__steam-cloud hero__steam-cloud--c"></span>
  </div>

  <div class="ember-field" aria-hidden="true">
    {
      [12, 28, 45, 62, 78, 88, 35, 55].map((left, i) => (
        <span
          class="ember"
          style={`left:${left}%; bottom:${(i % 4) * 8}%; --ember-dur:${8 + (i % 5)}s; --ember-delay:${i * 1.1}s;`}
        />
      ))
    }
  </div>

  <div class="hero__content container">
    {eyebrow && <p class="eyebrow hero__eyebrow" data-reveal="fade">{eyebrow}</p>}
    <h1 class="hero__title" data-reveal style="--reveal-delay: 60ms">{title}</h1>
    {subtitle && (
      <p class="hero__subtitle" data-reveal style="--reveal-delay: 140ms">
        {subtitle}
      </p>
    )}
    <div class="hero__actions" data-reveal style="--reveal-delay: 220ms">
      <CTAButton href={primaryCta.href} variant="primary" size="lg">{primaryCta.label}</CTAButton>
      {
        secondaryCta && (
          <CTAButton href={secondaryCta.href} variant="ghost" size="lg">
            {secondaryCta.label}
          </CTAButton>
        )
      }
    </div>
  </div>

  {
    !compact && (
      <a href="#main-content" class="hero__scroll" aria-label="Scroll to content">
        <span class="hero__scroll-line" aria-hidden="true"></span>
        <span class="hero__scroll-text">Explore</span>
      </a>
    )
  }

  <script is:inline>
    (function () {
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var hero = document.currentScript && document.currentScript.closest('.hero');
      var video = hero && hero.querySelector('video.hero__video');
      if (!video) return;
      if (prefersReduced) {
        video.pause();
        video.removeAttribute('autoplay');
      }
      window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', function (e) {
        if (e.matches) {
          video.pause();
        } else {
          video.play().catch(function () {});
        }
      });
    })();
  </script>
</section>

<style>
  .hero {
    position: relative;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(232, 93, 50, 0.14), transparent 58%),
      radial-gradient(80% 60% at 80% 100%, rgba(212, 161, 90, 0.08), transparent 50%),
      var(--wood-charred);
    min-height: clamp(520px, 88vh, 860px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero--compact {
    min-height: clamp(320px, 48vh, 480px);
  }
  .hero--center .hero__content {
    text-align: center;
    align-items: center;
    margin-inline: auto;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero__poster,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero__poster--atm {
    opacity: 0.55;
    filter: saturate(0.9) contrast(1.05);
    animation: hero-ken 28s var(--ease-in-out) infinite alternate;
  }
  @keyframes hero-ken {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }
  .hero__poster { z-index: 1; }
  .hero__video { z-index: 2; }

  .hero__steam {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }
  .hero__steam-cloud {
    position: absolute;
    width: 90%;
    height: 75%;
    background-image: var(--img-steam);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    filter: blur(8px);
    opacity: 0.2;
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  .hero__steam-cloud--a {
    top: 0;
    left: -30%;
    animation: steam-drift-a 28s var(--ease-in-out) infinite;
  }
  .hero__steam-cloud--b {
    bottom: -8%;
    right: -35%;
    width: 95%;
    opacity: 0.14;
    animation: steam-drift-b 34s var(--ease-in-out) infinite;
    animation-delay: -12s;
  }
  .hero__steam-cloud--c {
    top: 30%;
    left: 10%;
    width: 70%;
    height: 50%;
    opacity: 0.1;
    animation: steam-drift-a 40s var(--ease-in-out) infinite reverse;
    animation-delay: -6s;
  }
  @keyframes steam-drift-a {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.12; }
    50%  { transform: translate(32vw, 20px) scale(1.1); opacity: 0.28; }
    100% { transform: translate(68vw, 0) scale(1); opacity: 0.12; }
  }
  @keyframes steam-drift-b {
    0%   { transform: translate(0, 0) scale(1.05); opacity: 0.08; }
    50%  { transform: translate(-30vw, -16px) scale(1.14); opacity: 0.2; }
    100% { transform: translate(-65vw, 0) scale(1.05); opacity: 0.08; }
  }

  .hero .ember-field { z-index: 3; }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(13, 11, 9, 0.5) 0%,
        rgba(13, 11, 9, 0.28) 38%,
        rgba(13, 11, 9, 0.62) 78%,
        rgba(13, 11, 9, 0.92) 100%
      ),
      radial-gradient(120% 100% at 50% 50%, transparent 45%, rgba(13, 11, 9, 0.4) 100%);
  }
  .hero--left .hero__overlay {
    background:
      linear-gradient(
        180deg,
        rgba(13, 11, 9, 0.48) 0%,
        rgba(13, 11, 9, 0.25) 40%,
        rgba(13, 11, 9, 0.65) 80%,
        rgba(13, 11, 9, 0.94) 100%
      ),
      linear-gradient(90deg, rgba(13, 11, 9, 0.78) 0%, rgba(13, 11, 9, 0.4) 42%, transparent 72%);
  }

  .hero__content {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block: var(--space-8) var(--space-9);
    align-items: flex-start;
    max-width: min(var(--container-narrow), 92vw);
  }
  .hero--compact .hero__content {
    padding-block: var(--space-6) var(--space-7);
  }
  .hero__title {
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    max-width: 14ch;
    text-shadow: 0 4px 28px rgba(0, 0, 0, 0.55);
    background: linear-gradient(180deg, var(--birch-white) 0%, var(--birch-warm) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  /* Fallback if clip unsupported */
  @supports not (background-clip: text) {
    .hero__title { color: var(--birch-white); background: none; }
  }
  .hero__subtitle {
    font-size: var(--text-md);
    color: var(--color-ink);
    max-width: 48ch;
    line-height: var(--leading-loose);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .hero--center .hero__actions { justify-content: center; }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-ink-subtle);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    opacity: 0.75;
    transition: opacity var(--duration-fast) var(--ease-soft),
      color var(--duration-fast) var(--ease-soft);
  }
  .hero__scroll:hover {
    opacity: 1;
    color: var(--hot-coal-bright);
  }
  .hero__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, var(--hot-coal-bright), transparent);
    animation: scroll-pulse 2.2s var(--ease-in-out) infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.6); opacity: 0.4; transform-origin: top; }
    50% { transform: scaleY(1); opacity: 1; transform-origin: top; }
  }

  @media (max-width: 640px) {
    .hero { min-height: clamp(480px, 86vh, 720px); }
    .hero__title { font-size: var(--text-4xl); max-width: 12ch; }
    .hero__subtitle { font-size: var(--text-base); }
    .hero__overlay {
      background: linear-gradient(
        180deg,
        rgba(13, 11, 9, 0.6) 0%,
        rgba(13, 11, 9, 0.42) 40%,
        rgba(13, 11, 9, 0.78) 80%,
        rgba(13, 11, 9, 0.95) 100%
      );
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero__poster--atm { animation: none; }
  }
</style>
