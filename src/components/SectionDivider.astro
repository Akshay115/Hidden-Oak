---
/**
 * SectionDivider — ornamental break between page sections.
 * Centered birch/oak venik motif (generated SVG) flanked by hairline rules.
 */
interface Props {
  variant?: 'glyph' | 'line' | 'motif';
  class?: string;
}

const { variant = 'glyph', class: className = '' } = Astro.props;
---

<div class:list={['divider', `divider--${variant}`, className]} aria-hidden="true">
  <span class="divider__rule"></span>
  {
    variant === 'glyph' && (
      <span class="divider__glyph deco-motif deco-motif--glyph"></span>
    )
  }
  {
    variant === 'motif' && (
      <span class="divider__motif deco-motif"></span>
    )
  }
  <span class="divider__rule"></span>
</div>

<style>
  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-block: var(--space-5);
    color: var(--gold-ember);
    opacity: 0.9;
  }

  .divider__rule {
    display: block;
    height: 1px;
    width: clamp(60px, 18vw, 180px);
    background: linear-gradient(
      to var(--gradient-dir, right),
      transparent,
      var(--color-border-strong)
    );
  }

  .divider__rule:first-child {
    --gradient-dir: right;
    background: linear-gradient(to right, transparent, var(--color-border-strong));
  }
  .divider__rule:last-child {
    background: linear-gradient(to left, transparent, var(--color-border-strong));
  }

  .divider__glyph {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .divider__motif {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .divider--line {
    gap: 0;
  }
  .divider--line .divider__glyph,
  .divider--line .divider__motif {
    display: none;
  }
  .divider--line .divider__rule {
    width: 100%;
    max-width: var(--container-max);
    background: var(--color-border);
  }

  .divider--motif .divider__rule {
    width: clamp(40px, 12vw, 120px);
  }
</style>
