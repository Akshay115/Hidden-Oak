---
/**
 * Header — site nav. Sticky, translucent, active-link highlight.
 * Nav order: Home, The Banya, Services, Pricing, Gallery, [Book Now CTA], Location
 * "Book Now" renders as a highlighted CTA button in the flow, between Gallery and Location.
 *
 * Mobile menu uses a hidden checkbox + label (progressive enhancement, no JS).
 */
import CTAButton from './CTAButton.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/the-banya', label: 'The Banya' },
  { href: '/services', label: 'Services' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/gallery', label: 'Gallery' },
];

const ctaNav = { href: '/book', label: 'Book Now' };

const trailingNav = [
  { href: '/location', label: 'Location' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="site-header__inner container">
    <a href="/" class="brand" aria-label="Hidden Oak — home">
      <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true">
        <path
          d="M16 4c-1.2 1.6-3 2.2-4.4 3.2-2 1.4-3.4 3.6-3.4 6.2 0 1 .2 1.9.6 2.8-1.3.8-2.2 2.2-2.2 3.9 0 1.4.6 2.6 1.6 3.5-.4.7-.6 1.5-.6 2.4 0 .8.2 1.5.6 2.1-1.1.7-1.9 1.9-1.9 3.3 0 .5.1 1 .3 1.4h18.8c.2-.4.3-.9.3-1.4 0-1.4-.8-2.6-1.9-3.3.4-.6.6-1.3.6-2.1 0-.9-.2-1.7-.6-2.4 1-.9 1.6-2.1 1.6-3.5 0-1.7-.9-3.1-2.2-3.9.4-.9.6-1.8.6-2.8 0-2.6-1.4-4.8-3.4-6.2C19 6.2 17.2 5.6 16 4z"
          fill="currentColor"></path>
      </svg>
      <span class="brand__text">
        <span class="brand__name">Hidden Oak</span>
        <span class="brand__locale">Arambol · Goa, India</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="site-nav__cta-li">
          <CTAButton href={ctaNav.href} size="md" class="site-nav__cta">{ctaNav.label}</CTAButton>
        </li>
        {
          trailingNav.map((item) => (
            <li>
              <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: rgba(43, 29, 20, 0.82); /* var(--wood-charred) at 82% */
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: var(--header-height);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--clay-light);
    text-decoration: none;
  }
  .brand:hover { color: var(--hot-coal-bright); }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--birch-white);
  }
  .brand__locale {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
    margin-top: 2px;
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-nav__link {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    padding-block: var(--space-1);
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .site-nav__link:hover { color: var(--birch-white); }
  .site-nav__link.active {
    color: var(--hot-coal-bright);
    border-bottom-color: var(--hot-coal);
  }

  /* Pull the CTA slightly out from the text links with breathing room. */
  .site-nav__cta-li { margin-inline: var(--space-1); }
  :global(.site-nav__cta) { white-space: nowrap; }

  .nav-burger { display: none; }

  /* ---- Mobile: collapse into a disclosure panel ----------------------- */
  @media (max-width: 920px) {
    .nav-burger {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 28px;
      height: 22px;
      cursor: pointer;
    }
    .nav-burger span {
      display: block;
      height: 2px;
      width: 100%;
      background: var(--birch-white);
      border-radius: 2px;
      transition: transform var(--transition-fast), opacity var(--transition-fast);
    }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--wood-burnt);
      border-bottom: 1px solid var(--color-border);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: max-height var(--transition-base), opacity var(--transition-base);
    }
    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-3);
    }
    .site-nav__link {
      display: block;
      padding: var(--space-1) var(--space-1);
      font-size: var(--text-base);
    }
    .site-nav__cta-li { margin: var(--space-1) 0; }
    :global(.site-nav__cta) { width: 100%; }

    .nav-toggle:checked ~ .site-nav {
      max-height: 80vh;
      opacity: 1;
      pointer-events: auto;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(10px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-10px) rotate(-45deg);
    }
  }
</style>
