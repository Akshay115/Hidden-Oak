---
/**
 * Floating overlay nav — no sticky bar.
 * Logo + menu live over the hero image; solid glass appears only after scroll.
 */
import CTAButton from './CTAButton.astro';

const nav = [
  { href: '/the-banya', label: 'The Banya' },
  { href: '/services', label: 'Services' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/location', label: 'Location' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-nav-bar" id="site-header" data-scrolled="false">
  <div class="site-nav-bar__inner container">
    <a href="/" class="brand" aria-label="Hidden Oak — home">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
          <circle cx="20" cy="20" r="18.5" stroke="currentColor" stroke-width="1.2" opacity="0.45" />
          <path
            d="M20 8c0 0-7 7.5-7 13a7 7 0 0014 0c0-5.5-7-13-7-13z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
            fill="none"
          />
          <path
            d="M20 13v12M17.2 16.5c1.2-.7 2-1.4 2.8-2.4M22.8 16.5c-1.2-.7-2-1.4-2.8-2.4M17 20.5c1.4-.5 2.4-1.2 3-2.2M23 20.5c-1.4-.5-2.4-1.2-3-2.2"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
          />
          <!-- ice droplet accent -->
          <path d="M28 26c0 1.4-1.1 2.5-2.5 2.5S23 27.4 23 26c0-1.6 2.5-4.2 2.5-4.2S28 24.4 28 26z" fill="currentColor" opacity="0.55" />
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">Hidden Oak</span>
        <span class="brand__locale">Heat · Ice · Arambol</span>
      </span>
    </a>

    <button
      type="button"
      class="nav-burger"
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="primary-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="site-nav__cta-li">
          <CTAButton href="/book" size="md" class="site-nav__cta">Book</CTAButton>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background var(--duration-fast) var(--ease-soft),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft),
      backdrop-filter var(--duration-fast) var(--ease-soft);
  }

  /* Over hero: light text, glass-faint */
  .site-nav-bar:not([data-scrolled='true']) {
    background: linear-gradient(
      180deg,
      rgba(20, 16, 12, 0.42) 0%,
      rgba(20, 16, 12, 0.12) 70%,
      transparent 100%
    );
  }

  .site-nav-bar[data-scrolled='true'] {
    background: rgba(247, 243, 236, 0.88);
    backdrop-filter: saturate(160%) blur(18px);
    -webkit-backdrop-filter: saturate(160%) blur(18px);
    border-bottom-color: var(--color-border);
    box-shadow: 0 8px 28px rgba(47, 33, 24, 0.08);
  }

  .site-nav-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: var(--header-height);
    padding-block: 0.35rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-spring);
  }
  .brand:hover { transform: translateY(-1px); }

  .brand__mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: #fff8ef;
    background: rgba(255, 248, 239, 0.12);
    border: 1px solid rgba(255, 248, 239, 0.28);
    backdrop-filter: blur(8px);
    transition:
      color var(--duration-fast) var(--ease-soft),
      background var(--duration-fast) var(--ease-soft),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .site-nav-bar[data-scrolled='true'] .brand__mark {
    color: var(--forest-deep);
    background: linear-gradient(145deg, rgba(61, 90, 72, 0.12), rgba(255, 255, 255, 0.55));
    border-color: var(--color-border);
  }
  .brand:hover .brand__mark {
    box-shadow: 0 0 24px rgba(232, 93, 50, 0.25);
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: #fff8ef;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
    transition: color var(--duration-fast) var(--ease-soft);
  }
  .brand__locale {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: rgba(255, 248, 239, 0.78);
    margin-top: 3px;
    transition: color var(--duration-fast) var(--ease-soft);
  }
  .site-nav-bar[data-scrolled='true'] .brand__name {
    color: var(--forest-deep);
    text-shadow: none;
  }
  .site-nav-bar[data-scrolled='true'] .brand__locale {
    color: var(--color-ink-subtle);
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-nav__link {
    position: relative;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: rgba(255, 248, 239, 0.88);
    text-decoration: none;
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-pill);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.25);
    transition:
      color var(--duration-fast) var(--ease-soft),
      background var(--duration-fast) var(--ease-soft);
  }
  .site-nav__link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
  }
  .site-nav__link.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.14);
  }
  .site-nav-bar[data-scrolled='true'] .site-nav__link {
    color: var(--color-ink-muted);
    text-shadow: none;
  }
  .site-nav-bar[data-scrolled='true'] .site-nav__link:hover,
  .site-nav-bar[data-scrolled='true'] .site-nav__link.active {
    color: var(--forest-green);
    background: rgba(61, 90, 72, 0.08);
  }

  .site-nav__cta-li { margin-inline-start: 0.35rem; }
  :global(.site-nav__cta) { white-space: nowrap; }

  .nav-burger { display: none; }

  @media (max-width: 960px) {
    .nav-burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      width: 46px;
      height: 46px;
      background: rgba(255, 248, 239, 0.14);
      border: 1px solid rgba(255, 248, 239, 0.3);
      border-radius: var(--radius-md);
      cursor: pointer;
      gap: 5px;
      backdrop-filter: blur(10px);
      transition: border-color var(--duration-fast) var(--ease-soft),
        background var(--duration-fast) var(--ease-soft);
    }
    .site-nav-bar[data-scrolled='true'] .nav-burger {
      background: rgba(247, 243, 236, 0.9);
      border-color: var(--color-border);
    }
    .nav-burger span {
      display: block;
      height: 2px;
      width: 20px;
      background: #fff8ef;
      border-radius: 2px;
      transition: transform var(--duration-fast) var(--ease-soft),
        opacity var(--duration-fast) var(--ease-soft),
        background var(--duration-fast) var(--ease-soft);
    }
    .site-nav-bar[data-scrolled='true'] .nav-burger span {
      background: var(--forest-deep);
    }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(24, 18, 14, 0.96);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 248, 239, 0.1);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        max-height var(--duration-medium) var(--ease-out),
        opacity var(--duration-medium) var(--ease-out);
    }
    .site-nav-bar[data-scrolled='true'] .site-nav {
      background: rgba(247, 243, 236, 0.98);
      border-bottom-color: var(--color-border);
    }
    .site-nav--open {
      max-height: 85vh;
      opacity: 1;
      pointer-events: auto;
    }
    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-1);
      padding: var(--space-3) var(--space-3) var(--space-4);
    }
    .site-nav__link {
      display: flex;
      align-items: center;
      padding: var(--space-3);
      font-size: var(--text-base);
      min-height: 48px;
      border-radius: var(--radius-md);
      text-shadow: none;
      color: rgba(255, 248, 239, 0.9);
    }
    .site-nav-bar[data-scrolled='true'] .site-nav__link {
      color: var(--color-ink-muted);
    }
    .site-nav__cta-li { margin: var(--space-2) 0 0; }
    :global(.site-nav__cta) { width: 100%; min-height: 48px; }

    .nav-burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
    .nav-burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  (() => {
    const btn = document.getElementById('nav-toggle');
    const nav = document.getElementById('primary-nav');
    const header = document.getElementById('site-header');

    if (header) {
      // Pages without a hero (e.g. /book) need solid light nav immediately
      const hasHero = Boolean(document.querySelector('main .hero, main > .hero, .hero'));
      const onScroll = () => {
        if (!hasHero) {
          header.setAttribute('data-scrolled', 'true');
          return;
        }
        header.setAttribute('data-scrolled', String(window.scrollY > 40));
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    if (!btn || !nav) return;

    const toggle = (force?: boolean) => {
      const open = force !== undefined ? force : btn.getAttribute('aria-expanded') !== 'true';
      btn.setAttribute('aria-expanded', String(open));
      nav.classList.toggle('site-nav--open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    btn.addEventListener('click', () => toggle());
    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => toggle(false));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        toggle(false);
        btn.focus();
      }
    });
  })();
</script>
