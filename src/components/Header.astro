---
/**
 * Header — sticky glass nav with active states and mobile drawer.
 */
import CTAButton from './CTAButton.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/the-banya', label: 'The Banya' },
  { href: '/services', label: 'Services' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/gallery', label: 'Gallery' },
];

const ctaNav = { href: '/book', label: 'Book Now' };
const trailingNav = [{ href: '/location', label: 'Location' }];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-header" id="site-header" data-scrolled="false">
  <div class="site-header__inner container">
    <a href="/" class="brand" aria-label="Hidden Oak — home">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="32" height="32">
          <path
            d="M16 4c-1.2 1.6-3 2.2-4.4 3.2-2 1.4-3.4 3.6-3.4 6.2 0 1 .2 1.9.6 2.8-1.3.8-2.2 2.2-2.2 3.9 0 1.4.6 2.6 1.6 3.5-.4.7-.6 1.5-.6 2.4 0 .8.2 1.5.6 2.1-1.1.7-1.9 1.9-1.9 3.3 0 .5.1 1 .3 1.4h18.8c.2-.4.3-.9.3-1.4 0-1.4-.8-2.6-1.9-3.3.4-.6.6-1.3.6-2.1 0-.9-.2-1.7-.6-2.4 1-.9 1.6-2.1 1.6-3.5 0-1.7-.9-3.1-2.2-3.9.4-.9.6-1.8.6-2.8 0-2.6-1.4-4.8-3.4-6.2C19 6.2 17.2 5.6 16 4z"
            fill="currentColor"></path>
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">Hidden Oak</span>
        <span class="brand__locale">Arambol · Goa</span>
      </span>
    </a>

    <button
      type="button"
      class="nav-burger"
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="primary-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="site-nav__cta-li">
          <CTAButton href={ctaNav.href} size="md" class="site-nav__cta">{ctaNav.label}</CTAButton>
        </li>
        {
          trailingNav.map((item) => (
            <li>
              <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: rgba(30, 21, 16, 0.55);
    backdrop-filter: saturate(150%) blur(16px);
    -webkit-backdrop-filter: saturate(150%) blur(16px);
    border-bottom: 1px solid transparent;
    transition:
      background var(--duration-fast) var(--ease-soft),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .site-header[data-scrolled='true'] {
    background: rgba(30, 21, 16, 0.9);
    border-bottom-color: var(--color-border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: var(--header-height);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-spring);
  }
  .brand:hover { transform: translateY(-1px); }
  .brand__mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--gold-ember);
    background: linear-gradient(145deg, rgba(196, 106, 40, 0.22), rgba(30, 21, 16, 0.5));
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-inset);
    transition: color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .brand:hover .brand__mark {
    color: var(--hot-coal-bright);
    box-shadow: var(--shadow-glow-soft);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--birch-white);
  }
  .brand__locale {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
    margin-top: 3px;
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-nav__link {
    position: relative;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 0.55rem 0.85rem;
    border-radius: var(--radius-pill);
    transition:
      color var(--duration-fast) var(--ease-soft),
      background var(--duration-fast) var(--ease-soft);
  }
  .site-nav__link:hover {
    color: var(--birch-white);
    background: rgba(244, 234, 212, 0.06);
  }
  .site-nav__link.active {
    color: var(--hot-coal-bright);
    background: rgba(232, 93, 50, 0.1);
  }
  .site-nav__link.active::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 4px;
    width: 14px;
    height: 2px;
    border-radius: 2px;
    background: var(--hot-coal);
    transform: translateX(-50%);
  }

  .site-nav__cta-li { margin-inline: var(--space-1) 0; }
  :global(.site-nav__cta) { white-space: nowrap; }

  .nav-burger { display: none; }

  @media (max-width: 960px) {
    .nav-burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      width: 46px;
      height: 46px;
      background: rgba(47, 33, 24, 0.7);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      cursor: pointer;
      gap: 5px;
      transition: border-color var(--duration-fast) var(--ease-soft);
    }
    .nav-burger span {
      display: block;
      height: 2px;
      width: 20px;
      background: var(--birch-white);
      border-radius: 2px;
      transition: transform var(--duration-fast) var(--ease-soft),
        opacity var(--duration-fast) var(--ease-soft);
    }
    .nav-burger:hover { border-color: var(--color-border-strong); }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(30, 21, 16, 0.97);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--color-border);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        max-height var(--duration-medium) var(--ease-out),
        opacity var(--duration-medium) var(--ease-out);
    }
    .site-nav--open {
      max-height: 85vh;
      opacity: 1;
      pointer-events: auto;
    }
    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-1);
      padding: var(--space-3) var(--space-3) var(--space-4);
    }
    .site-nav__link {
      display: flex;
      align-items: center;
      padding: var(--space-3) var(--space-3);
      font-size: var(--text-base);
      min-height: 48px;
      border-radius: var(--radius-md);
    }
    .site-nav__link.active::after { display: none; }
    .site-nav__cta-li { margin: var(--space-2) 0 0; }
    :global(.site-nav__cta) { width: 100%; min-height: 48px; }

    .nav-burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
    .nav-burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  (() => {
    const btn = document.getElementById('nav-toggle');
    const nav = document.getElementById('primary-nav');
    const header = document.getElementById('site-header');

    if (header) {
      const onScroll = () => {
        header.setAttribute('data-scrolled', String(window.scrollY > 12));
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    if (!btn || !nav) return;

    const toggle = (force?: boolean) => {
      const open = force !== undefined ? force : btn.getAttribute('aria-expanded') !== 'true';
      btn.setAttribute('aria-expanded', String(open));
      nav.classList.toggle('site-nav--open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    btn.addEventListener('click', () => toggle());
    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => toggle(false));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        toggle(false);
        btn.focus();
      }
    });
  })();
</script>
