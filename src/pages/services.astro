---
/**
 * Services & Benefits — /services
 *
 * Practical, scannable counterpart to /the-banya (which tells the story).
 * This page exists to reduce hesitation before someone books:
 *   - what each part of the session actually is and feels like
 *   - the two walk-in options compared side by side
 *   - the six most common first-timer questions, answered plainly
 *
 * Tone: reassuring and clear. Plain language only — no medical/health claims
 * that can't be substantiated. Benefits described as "how it feels," not
 * "what it treats."
 *
 * Heading hierarchy: h1 in Hero, h2 per major section, h3 for sub-blocks.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

// The two walk-in options compared in section 4.
const sessions = [
  {
    name: 'Without Ice Bath',
    badge: 'Base session',
    duration: '~75 min',
    includes: [
      'Sauna & steam room',
      'Two or three heat rounds',
      'Shower access throughout',
      'Rest area with tea',
    ],
    note: 'The full banya experience, without the cold plunge.',
  },
  {
    name: 'With Ice Bath',
    badge: 'Most popular',
    duration: '~90 min',
    includes: [
      'Everything in the base session',
      'Cold plunge between rounds',
      'Guided first plunge (if you want it)',
      'Contrast therapy cycle',
    ],
    note: 'Heat and cold together — the traditional full cycle.',
    featured: true,
  },
];

// Section 5 — FAQ. Accordion via native <details>. Reassuring, plain answers.
const faqs = [
  {
    q: 'Is it safe?',
    a: 'For the great majority of people, yes. But banya isn’t for everyone. If you’re pregnant, have a heart condition, high or low blood pressure, or you’re managing a medical condition, it’s worth checking with your doctor before booking. On the day, we’ll check in with you before you start, and you can step out of any room at any point — there’s no pressure to push through anything that doesn’t feel right.',
  },
  {
    q: 'What should I wear?',
    a: 'Whatever you’re comfortable in. Most people wear a swimsuit or trunks. We provide towels, and the changing area is private. For the steam room, less is genuinely better — the heat works best against bare skin, and it’s the traditional way. But wear what lets you relax.',
  },
  {
    q: 'How hot does it get?',
    a: 'The steam room sits somewhere between 60°C and 90°C (140–195°F), depending on the bench you’re on — the higher you sit, the warmer it is. The wet steam itself is cooler than the dry heat, but it feels intense because of the humidity. You can always move to a lower bench or step out for air.',
  },
  {
    q: 'Can beginners do the ice bath?',
    a: 'Yes — most first-timers are surprised by how manageable it is. The ice bath is an optional add-on, never required, and you don’t have to commit to it in advance. When you’re warmed up and ready, we’ll talk you through the first plunge: how to breathe, how to get in, and roughly how long to stay (for a beginner, that’s often just 30 seconds to a minute). You can get out whenever you like.',
  },
  {
    q: 'How long should I stay?',
    a: 'A typical session runs about 75 to 90 minutes, broken into two or three rounds of heat with rest in between. You don’t stay in the steam room the whole time — each round is usually 10 to 20 minutes, with breaks to cool down and drink tea. Longer isn’t better. Listen to your body and step out when you’ve had enough.',
  },
  {
    q: 'Do I need to book in advance?',
    a: 'Yes — booking ahead is required so we can have the room warm and ready for you. Same-day bookings are sometimes possible depending on availability. The easiest way is to pick a slot through our booking page; you’ll get a confirmation by email and a reminder the day before.',
  },
];
---

<BaseLayout
  title="Services & Benefits"
  description="What to expect at Hidden Oak banya: the sauna and steam session, the ice bath, the shower, session options, and answers to the questions first-timers ask most."
>
  <Hero
    eyebrow="What You'll Experience"
    title="Services & Benefits"
    subtitle="Everything you need to know before your first visit — without the jargon."
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/pricing', label: 'See Pricing' }}
  />

  {/* ============================================================
       1. THE SAUNA / STEAM SESSION
  ============================================================ */}
  <section class="section" id="sauna-steam" data-reveal>
    <div class="container feature-block">
      <div class="feature-block__head">
        <span class="feature-block__num" aria-hidden="true">01</span>
        <div>
          <p class="eyebrow">The heart of it</p>
          <h2>The sauna & steam session</h2>
        </div>
      </div>

      <div class="feature-block__body">
        <div class="feature-block__copy">
          <h3>What it is</h3>
          <p>
            A warm room of wood and stone, heated to somewhere between 60°C and
            90°C (140–195°F). You sit, you breathe, you let the heat
            do its work. Water is ladled onto hot stones to make steam — which
            raises the humidity and makes the warmth feel deeper, not hotter.
          </p>

          <h3>How long</h3>
          <p>
            A full session runs about 75 to 90 minutes, broken into two or three
            <em>rounds</em> of 10 to 20 minutes each in the heat, with rest in
            between. You never stay in for the whole session — the rhythm of
            warming up, cooling off, and warming up again is the whole point.
          </p>

          <h3>What it feels like</h3>
          <p>
            The first few minutes can feel like a lot. Then the body settles,
            breathing slows, and the heat stops being something you notice and
            becomes something you sink into. People usually come out moving
            looser, with their shoulders dropped and their head clearer.
          </p>
        </div>

        <aside class="feature-block__benefits" aria-label="What people notice">
          <h3>What people notice</h3>
          <ul>
            <li>Tense muscles feel looser and softer</li>
            <li>Circulation gets going — a warm, flushed feeling</li>
            <li>The mind quietly settles, the way it does after a long walk</li>
            <li>You sleep well that night</li>
            <li>Skin feels clean and open</li>
          </ul>
          <p class="feature-block__disclaimer">
            These are how people describe the experience, not medical claims. If
            you have a health condition, please check with your doctor first.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       2. THE ICE BATH
  ============================================================ */}
  <section class="section" id="ice-bath" data-reveal>
    <div class="container feature-block">
      <div class="feature-block__head">
        <span class="feature-block__num" aria-hidden="true">02</span>
        <div>
          <p class="eyebrow">Optional add-on</p>
          <h2>The ice bath</h2>
        </div>
      </div>

      <div class="feature-block__body">
        <div class="feature-block__copy">
          <h3>What it is</h3>
          <p>
            A tub of cold water — held somewhere between 5°C and 12°C
            (41–54°F) — that you step into after a round in the heat.
            You stay in for somewhere between 30 seconds and a few minutes.
            That’s it. Short, sharp, and over before you know it.
          </p>

          <h3>Why pair it with heat</h3>
          <p>
            Heat opens things up; cold closes them back down. Going from warm to
            cold and back again — what’s sometimes called contrast therapy
            — is the traditional heart of the banya, and it’s where the
            real feeling of reset comes from. One without the other is only half
            the practice. Many people find the cold the part they remember most.
          </p>

          <h3>If it’s your first time</h3>
          <p>
            You don’t have to commit in advance, and you don’t have to do
            it at all. When you’re warmed up and curious, we’ll talk you
            through it: how to breathe (slowly, out), how to get in (gradually,
            not all at once), and roughly how long to stay (for a first-timer,
            that’s often just 30 seconds to a minute). You can get out the
            moment you want to. Most people are surprised by how manageable it is
            — and how good they feel after.
          </p>
        </div>

        <aside class="feature-block__benefits" aria-label="What people notice">
          <h3>What people notice</h3>
          <ul>
            <li>An immediate, full-body wake-up</li>
            <li>Feeling clear and alert for hours after</li>
            <li>A sense of having done something genuinely impressive</li>
            <li>The heat round that follows feels even better</li>
          </ul>
          <p class="feature-block__disclaimer">
            Always optional. Skip it entirely if it’s not for you — the
            base session is complete on its own.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       3. THE SHOWER
  ============================================================ */}
  <section class="section" id="shower" data-reveal>
    <div class="container feature-block feature-block--slim">
      <div class="feature-block__head">
        <span class="feature-block__num" aria-hidden="true">03</span>
        <div>
          <p class="eyebrow">Included</p>
          <h2>The shower</h2>
        </div>
      </div>
      <div class="feature-block__body feature-block__body--single">
        <div class="feature-block__copy">
          <p>
            Every session includes access to a private shower, with towels and
            natural soap provided. Rinse off before you begin, and again at the
            end before you head back out into the world. Nothing complicated
            — just warm water, a clean finish, and somewhere to change in
            private.
          </p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       4. CHOOSE YOUR SESSION
  ============================================================ */}
  <section class="section" id="choose" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">Two ways to visit</p>
        <h2>Choose your session</h2>
        <p class="lede">
          Both options include the full sauna and steam experience. The only
          difference is whether you add the ice bath.
        </p>
      </div>

      <div class="session-grid">
        {
          sessions.map((s, i) => (
            <article
              class:list={['session-card', { 'session-card--featured': s.featured }]}
              data-reveal
              style={`--reveal-delay: ${i * 80}ms`}
            >
              {s.badge && <span class="session-card__badge">{s.badge}</span>}
              <h3>{s.name}</h3>
              <p class="session-card__duration">{s.duration}</p>
              <ul class="session-card__list">
                {s.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <p class="session-card__note">{s.note}</p>
              <CTAButton
                href="/book"
                variant={s.featured ? 'primary' : 'ghost'}
                size="md"
                class="session-card__cta"
              >
                Book this session
              </CTAButton>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       5. FAQ
  ============================================================ */}
  <section class="section" id="faq" data-reveal>
    <div class="container narrow">
      <div class="block-head">
        <p class="eyebrow">First-timers</p>
        <h2>Questions before you book</h2>
        <p class="lede">
          If something’s holding you back, there’s a decent chance
          it’s on this list. If not, we’re happy to answer it directly.
        </p>
      </div>

      <div class="faq">
        {
          faqs.map((item) => (
            <details class="faq__item">
              <summary>
                <span>{item.q}</span>
              </summary>
              <div class="faq__answer">
                <p>{item.a}</p>
              </div>
            </details>
          ))
        }
      </div>

      <div class="faq__cta">
        <p>Still have a question?</p>
        <a href="/location">Get in touch →</a>
      </div>
    </div>
  </section>

  {/* ============================================================
       CTA BAND
  ============================================================ */}
  <section class="section" data-reveal>
    <div class="container cta-band">
      <div>
        <p class="eyebrow">Ready when you are</p>
        <h2>You’ve read enough. Come feel it.</h2>
        <p class="lede">
          First-timers are always welcome. We’ll walk you through every step.
        </p>
      </div>
      <CTAButton href="/book" variant="primary" size="lg">Book a Session</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- shared section heading ---------------------------------------- */
  .block-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-5);
    max-width: var(--container-narrow);
  }
  .block-head h2 { max-width: 20ch; }
  .narrow { max-width: var(--container-narrow); }

  /* ---- feature blocks (sections 1–3) -------------------------------- */
  .feature-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .feature-block__head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .feature-block__num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-bold);
    line-height: 1.4;
    flex-shrink: 0;
  }
  .feature-block__head h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-1);
  }

  .feature-block__body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  .feature-block__body--single {
    grid-template-columns: 1fr;
    max-width: var(--container-narrow);
  }
  .feature-block__copy h3 {
    font-size: var(--text-lg);
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
    color: var(--birch-white);
  }
  .feature-block__copy h3:first-child { margin-top: 0; }
  .feature-block__copy p {
    font-size: var(--text-base);
    color: var(--color-ink-muted);
    line-height: var(--leading-loose);
  }

  /* ---- benefits aside ------------------------------------------------ */
  .feature-block__benefits {
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    position: sticky;
    top: calc(var(--header-height) + var(--space-3));
  }
  .feature-block__benefits h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
    margin-bottom: var(--space-3);
  }
  .feature-block__benefits ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .feature-block__benefits li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .feature-block__benefits li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: var(--weight-bold);
  }
  .feature-block__disclaimer {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    line-height: var(--leading-normal);
    font-style: italic;
  }

  /* ---- session comparison cards -------------------------------------- */
  .session-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
    align-items: stretch;
  }
  .session-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }
  .session-card--featured {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-glow);
  }
  .session-card__badge {
    position: absolute;
    top: calc(-1 * var(--space-2));
    left: var(--space-4);
    background: var(--clay-deep);          /* AA-safe contrast with birch-white text */
    color: var(--birch-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
  }
  .session-card h3 {
    font-size: var(--text-xl);
    color: var(--birch-white);
    margin-top: var(--space-1);
  }
  .session-card__duration {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-semibold);
  }
  .session-card__list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .session-card__list li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .session-card__list li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: var(--weight-bold);
  }
  .session-card__note {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    font-style: italic;
    margin-bottom: var(--space-2);
  }
  .session-card__cta { margin-top: auto; width: 100%; }

  /* ---- FAQ accordion ------------------------------------------------- */
  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }
  .faq__item {
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--ease-soft);
  }
  .faq__item[open] { border-color: var(--color-border-strong); }
  .faq__item summary {
    cursor: pointer;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    color: var(--birch-white);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    transition: color var(--duration-fast) var(--ease-soft);
  }
  .faq__item summary:hover { color: var(--hot-coal-bright); }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--hot-coal-bright);
    transition: transform var(--duration-fast) var(--ease-soft);
    flex-shrink: 0;
  }
  .faq__item[open] summary::after { transform: rotate(45deg); }
  .faq__item[open] summary {
    border-bottom: 1px solid var(--color-border);
  }

  /* Animated expand/collapse using the grid-template-rows 0fr → 1fr trick.
     The wrapper grid animates its row from 0 to auto height smoothly.
     Fallback: browsers without fr-unit animation get instant show/hide,
     which is acceptable. */
  .faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-medium) var(--ease-out);
  }
  .faq__item[open] .faq__answer {
    grid-template-rows: 1fr;
  }
  .faq__answer > p {
    overflow: hidden;
    padding: 0 var(--space-4);
    transition: padding var(--duration-medium) var(--ease-out);
  }
  .faq__item[open] .faq__answer > p {
    padding: var(--space-3) var(--space-4) var(--space-4);
  }
  .faq__answer p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-loose);
  }
  .faq__cta {
    margin-top: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-ink-subtle);
    font-size: var(--text-sm);
  }
  .faq__cta a { font-weight: var(--weight-semibold); }

  /* ---- CTA band ------------------------------------------------------ */
  .cta-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }
  @media (max-width: 720px) {
    .feature-block__body { grid-template-columns: 1fr; }
    .feature-block__benefits {
      position: static;
    }
    .cta-band { flex-direction: column; align-items: flex-start; }
  }
</style>
