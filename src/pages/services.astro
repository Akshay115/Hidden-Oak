---
/**
 * Services & Benefits — practical, image-first guide to heat + ice.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

const sessions = [
  {
    name: 'Without Ice Bath',
    badge: 'Base session',
    duration: '~75 min',
    icon: 'flame' as const,
    includes: [
      'Sauna & steam room',
      'Two or three heat rounds',
      'Shower access throughout',
      'Rest area with tea',
    ],
    note: 'The full banya experience, without the cold plunge.',
  },
  {
    name: 'With Ice Bath',
    badge: 'Most popular',
    duration: '~90 min',
    icon: 'snowflake' as const,
    includes: [
      'Everything in the base session',
      'Cold plunge between rounds',
      'Guided first plunge (if you want it)',
      'Contrast therapy cycle',
    ],
    note: 'Heat and cold together — the traditional full cycle.',
    featured: true,
  },
];

const faqs = [
  {
    q: 'Is it safe?',
    a: 'For the great majority of people, yes. But banya isn’t for everyone. If you’re pregnant, have a heart condition, high or low blood pressure, or you’re managing a medical condition, it’s worth checking with your doctor before booking. On the day, we’ll check in with you before you start, and you can step out of any room at any point — there’s no pressure to push through anything that doesn’t feel right.',
  },
  {
    q: 'What should I wear?',
    a: 'Whatever you’re comfortable in. Most people wear a swimsuit or trunks. We provide towels, and the changing area is private. For the steam room, less is genuinely better — the heat works best against bare skin, and it’s the traditional way. But wear what lets you relax.',
  },
  {
    q: 'How hot does it get?',
    a: 'The steam room sits somewhere between 60°C and 90°C (140–195°F), depending on the bench you’re on — the higher you sit, the warmer it is. The wet steam itself is cooler than the dry heat, but it feels intense because of the humidity. You can always move to a lower bench or step out for air.',
  },
  {
    q: 'Can beginners do the ice bath?',
    a: 'Yes — most first-timers are surprised by how manageable it is. The ice bath is an optional add-on, never required, and you don’t have to commit to it in advance. When you’re warmed up and ready, we’ll talk you through the first plunge: how to breathe, how to get in, and roughly how long to stay (for a beginner, that’s often just 30 seconds to a minute). You can get out whenever you like.',
  },
  {
    q: 'How long should I stay?',
    a: 'A typical session runs about 75 to 90 minutes, broken into two or three rounds of heat with rest in between. You don’t stay in the steam room the whole time — each round is usually 10 to 20 minutes, with breaks to cool down and drink tea. Longer isn’t better. Listen to your body and step out when you’ve had enough.',
  },
  {
    q: 'Do I need to book in advance?',
    a: 'Yes — booking ahead is required so we can have the room warm and ready for you. Same-day bookings are sometimes possible depending on availability. The easiest way is to pick a slot through our booking page; you’ll get a confirmation by email and a reminder the day before.',
  },
];
---

<BaseLayout
  title="Services & Benefits"
  description="What to expect at Hidden Oak banya: the sauna and steam session, the ice bath, the shower, session options, and answers to the questions first-timers ask most."
>
  <Hero
    compact
    dual
    eyebrow="What You'll Experience"
    title="Heat, ice & everything between."
    subtitle="The full ritual — wood-fired steam, optional cold plunge, rest, and tea — explained plainly."
    poster="/images/gallery/sauna-steam.jpg"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/pricing', label: 'See Pricing' }}
  />

  {/* Visual dual intro */}
  <section class="section dual-intro" data-reveal>
    <div class="container dual-intro__grid">
      <a href="#sauna-steam" class="snap snap--heat">
        <img src="/images/gallery/sauna-stove.jpg" alt="Wood-fired stove in the sauna" loading="lazy" decoding="async" />
        <div class="snap__label">
          <span class="deco-icon deco-icon--sm deco-icon--flame"></span>
          01 · Heat
        </div>
      </a>
      <a href="#ice-bath" class="snap snap--ice">
        <img src="/images/gallery/ice-tub.jpg" alt="Ice bath cold plunge tub" loading="lazy" decoding="async" />
        <div class="snap__label">
          <span class="deco-icon deco-icon--sm deco-icon--snowflake"></span>
          02 · Ice
        </div>
      </a>
    </div>
  </section>

  {/* SAUNA */}
  <section class="section section--heat" id="sauna-steam" data-reveal>
    <div class="container feature">
      <div class="feature__visual">
        <img src="/images/gallery/sauna-bench.jpg" alt="Wooden benches inside the steam room" loading="lazy" decoding="async" />
      </div>
      <div class="feature__copy">
        <div class="feature__head">
          <span class="icon-badge" aria-hidden="true">
            <span class="deco-icon deco-icon--md deco-icon--flame"></span>
          </span>
          <div>
            <p class="eyebrow">The heart of it</p>
            <h2>The sauna & steam</h2>
          </div>
        </div>
        <h3>What it is</h3>
        <p>
          A warm room of wood and stone, heated to somewhere between 60°C and
          90°C. You sit, you breathe, you let the heat do its work. Water is
          ladled onto hot stones to make light steam — deeper warmth, not harsher heat.
        </p>
        <h3>How long</h3>
        <p>
          A full session runs about 75 to 90 minutes, broken into two or three
          rounds of 10 to 20 minutes in the heat, with rest in between.
          The rhythm of warming, cooling, and warming again is the whole point.
        </p>
        <h3>What it feels like</h3>
        <p>
          The first few minutes can feel like a lot. Then the body settles,
          breathing slows, and the heat becomes something you sink into.
          People usually come out looser, clearer, ready for cold — or for tea.
        </p>
        <aside class="feature__aside surface-card">
          <h3>What people notice</h3>
          <ul>
            <li>Tense muscles feel looser</li>
            <li>A warm, flushed circulation</li>
            <li>The mind quietly settles</li>
            <li>Sleep comes easier that night</li>
          </ul>
          <p class="feature__note">How people describe the experience — not medical claims.</p>
        </aside>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ICE */}
  <section class="section section--ice" id="ice-bath" data-reveal>
    <div class="container feature feature--flip">
      <div class="feature__visual feature__visual--ice">
        <img src="/images/gallery/ice-tub.jpg" alt="Cedar cold plunge tub filled with ice water" loading="lazy" decoding="async" />
        <img class="feature__visual-sub" src="/images/gallery/ice-detail.jpg" alt="Close-up of cold water surface" loading="lazy" decoding="async" />
      </div>
      <div class="feature__copy">
        <div class="feature__head">
          <span class="icon-badge icon-badge--ice" aria-hidden="true">
            <span class="deco-icon deco-icon--md deco-icon--snowflake"></span>
          </span>
          <div>
            <p class="eyebrow">Optional · unforgettable</p>
            <h2>The ice bath</h2>
          </div>
        </div>
        <h3>What it is</h3>
        <p>
          A tub of cold water — held somewhere between 5°C and 12°C — that you
          step into after a round in the heat. Stay 30 seconds to a few minutes.
          Short, sharp, and over before you know it.
        </p>
        <h3>Why pair it with heat</h3>
        <p>
          Heat opens; cold closes. Going from warm to cold and back again is the
          traditional heart of the banya — and where the real feeling of reset comes from.
          Many people find the ice the part they remember most.
        </p>
        <h3>If it’s your first time</h3>
        <p>
          You don’t have to commit in advance, and you don’t have to do it at all.
          We’ll talk you through breathing, how to get in, and how long to stay.
          Most people are surprised by how manageable it is — and how good they feel after.
        </p>
        <aside class="feature__aside feature__aside--ice surface-card">
          <h3>What people notice</h3>
          <ul>
            <li>An immediate full-body wake-up</li>
            <li>Clear and alert for hours after</li>
            <li>Pride at having done something real</li>
            <li>The next heat round feels even better</li>
          </ul>
          <p class="feature__note">Always optional. The base session is complete on its own.</p>
        </aside>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* SHOWER */}
  <section class="section" id="shower" data-reveal>
    <div class="container shower-row">
      <div>
        <p class="eyebrow">Included</p>
        <h2>The shower</h2>
        <p class="lede">
          Every session includes a private shower, with towels and natural soap.
          Rinse before you begin, and again at the end — warm water, a clean finish,
          and somewhere private to change.
        </p>
      </div>
      <figure class="img-panel shower-row__img">
        <img src="/images/gallery/detail-wood-grain.jpg" alt="Warm wood detail near the wash area" loading="lazy" decoding="async" />
        <figcaption class="img-panel__caption">Wood & water</figcaption>
      </figure>
    </div>
  </section>

  <SectionDivider />

  {/* CHOOSE */}
  <section class="section" id="choose" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">Two ways to visit</p>
        <h2>Choose your session</h2>
        <p class="lede">
          Both include the full sauna and steam experience. The only difference is the ice bath.
        </p>
      </div>

      <div class="session-grid">
        {
          sessions.map((s, i) => (
            <article
              class:list={['session-card surface-card', { 'session-card--featured': s.featured }]}
              data-reveal
              style={`--reveal-delay: ${i * 80}ms`}
            >
              {s.badge && <span class="session-card__badge">{s.badge}</span>}
              <span
                class:list={['session-card__icon', 'deco-icon', 'deco-icon--md', `deco-icon--${s.icon}`]}
                aria-hidden="true"
              ></span>
              <h3>{s.name}</h3>
              <p class="session-card__duration">{s.duration}</p>
              <ul class="session-card__list">
                {s.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <p class="session-card__note">{s.note}</p>
              <CTAButton
                href="/book"
                variant={s.featured ? 'primary' : 'ghost'}
                size="md"
                class="session-card__cta"
              >
                Book this session
              </CTAButton>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* FAQ */}
  <section class="section" id="faq" data-reveal>
    <div class="container narrow">
      <div class="block-head">
        <p class="eyebrow">First-timers</p>
        <h2>Questions before you book</h2>
        <p class="lede">
          If something’s holding you back, there’s a decent chance it’s on this list.
        </p>
      </div>

      <div class="faq">
        {
          faqs.map((item) => (
            <details class="faq__item surface-card">
              <summary>
                <span>{item.q}</span>
              </summary>
              <div class="faq__answer">
                <p>{item.a}</p>
              </div>
            </details>
          ))
        }
      </div>

      <div class="faq__cta">
        <p>Still have a question?</p>
        <a href="/location">Get in touch →</a>
      </div>
    </div>
  </section>

  <section class="section" data-reveal>
    <div class="container cta-band">
      <div>
        <p class="eyebrow">Ready when you are</p>
        <h2>You’ve read enough. Come feel it.</h2>
        <p class="lede">First-timers are always welcome. We’ll walk you through every step.</p>
      </div>
      <CTAButton href="/book" variant="primary" size="lg">Book a Session</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  .block-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-5);
    max-width: var(--container-narrow);
  }
  .block-head h2 { max-width: 20ch; color: var(--forest-deep); }
  .narrow { max-width: var(--container-narrow); }

  .dual-intro { padding-block: var(--space-5); }
  .dual-intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .snap {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    text-decoration: none;
  }
  .snap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out), filter var(--duration-medium) var(--ease-soft);
  }
  .snap--heat img { filter: brightness(1.1) saturate(1.1); }
  .snap--ice img { filter: brightness(1.14) saturate(0.95); }
  .snap:hover img { transform: scale(1.05); }
  .snap__label {
    position: absolute;
    left: var(--space-3);
    bottom: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(20, 14, 10, 0.5);
    backdrop-filter: blur(10px);
    color: #fff8ef;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .feature {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-6);
    align-items: start;
  }
  .feature--flip .feature__visual { order: 2; }
  .feature--flip .feature__copy { order: 1; }
  .feature__visual {
    position: sticky;
    top: calc(var(--header-height) + var(--space-3));
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    min-height: 420px;
    box-shadow: var(--shadow-md);
  }
  .feature__visual img {
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    filter: brightness(1.08) saturate(1.06);
  }
  .feature__visual--ice {
    display: grid;
    grid-template-rows: 1.4fr 0.8fr;
    gap: var(--space-2);
    background: transparent;
    border: none;
    box-shadow: none;
    min-height: auto;
  }
  .feature__visual--ice > img:first-child {
    border-radius: var(--radius-2xl);
    min-height: 300px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
  }
  .feature__visual-sub {
    border-radius: var(--radius-xl) !important;
    min-height: 160px !important;
    border: 1px solid var(--color-border);
    filter: brightness(1.15) saturate(0.9) !important;
  }
  .feature__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .feature__head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .feature__head h2 {
    font-size: var(--text-2xl);
    color: var(--forest-deep);
    margin-top: 0.15rem;
  }
  .icon-badge--ice {
    color: var(--ice-deep);
    background: linear-gradient(145deg, rgba(126, 182, 212, 0.22), rgba(255, 255, 255, 0.5));
  }
  .feature__copy h3 {
    font-size: var(--text-lg);
    margin-top: var(--space-3);
    color: var(--forest-deep);
  }
  .feature__copy > p {
    font-size: var(--text-base);
    color: var(--color-ink-muted);
    line-height: var(--leading-loose);
  }
  .feature__aside {
    margin-top: var(--space-4);
    padding: var(--space-4);
  }
  .feature__aside h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
    margin: 0 0 var(--space-3);
  }
  .feature__aside ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .feature__aside li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .feature__aside li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: bold;
  }
  .feature__aside--ice li::before { color: var(--ice-deep); }
  .feature__note {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    font-style: italic;
  }

  .shower-row {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-6);
    align-items: center;
  }
  .shower-row h2 { color: var(--forest-deep); }
  .shower-row__img { min-height: 280px; aspect-ratio: 4/3; }

  .session-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  .session-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
  }
  .session-card--featured {
    border-color: var(--ice-mid);
    box-shadow: var(--shadow-md), 0 0 32px var(--ice-glow);
  }
  .session-card__badge {
    position: absolute;
    top: calc(-1 * var(--space-2));
    left: var(--space-4);
    background: var(--clay-deep);
    color: var(--birch-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
  }
  .session-card__icon { color: var(--hot-coal-bright); margin-top: var(--space-1); }
  .session-card--featured .session-card__icon { color: var(--ice-deep); }
  .session-card h3 {
    font-size: var(--text-xl);
    color: var(--forest-deep);
    margin-top: var(--space-1);
  }
  .session-card__duration {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-semibold);
  }
  .session-card--featured .session-card__duration { color: var(--ice-deep); }
  .session-card__list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .session-card__list li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .session-card__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: bold;
  }
  .session-card__note {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    font-style: italic;
    margin-bottom: var(--space-2);
  }
  .session-card__cta { margin-top: auto; width: 100%; }

  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }
  .faq__item {
    overflow: hidden;
    padding: 0;
  }
  .faq__item summary {
    cursor: pointer;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    color: var(--forest-deep);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--hot-coal-bright);
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-soft);
  }
  .faq__item[open] summary::after { transform: rotate(45deg); }
  .faq__item[open] summary { border-bottom: 1px solid var(--color-border); }
  .faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-medium) var(--ease-out);
  }
  .faq__item[open] .faq__answer { grid-template-rows: 1fr; }
  .faq__answer > p {
    overflow: hidden;
    padding: 0 var(--space-4);
    transition: padding var(--duration-medium) var(--ease-out);
  }
  .faq__item[open] .faq__answer > p {
    padding: var(--space-3) var(--space-4) var(--space-4);
  }
  .faq__answer p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-loose);
  }
  .faq__cta {
    margin-top: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-ink-subtle);
    font-size: var(--text-sm);
  }
  .faq__cta a { font-weight: var(--weight-semibold); }

  @media (max-width: 880px) {
    .feature,
    .feature--flip { grid-template-columns: 1fr; }
    .feature--flip .feature__visual,
    .feature--flip .feature__copy { order: unset; }
    .feature__visual { position: static; min-height: 280px; }
    .feature__visual img { min-height: 280px; }
    .shower-row { grid-template-columns: 1fr; }
    .dual-intro__grid { grid-template-columns: 1fr; }
  }
</style>
