---
/**
 * Location & Contact — /location
 * Map embed, address, directions, opening hours, contact form.
 * The form has no backend yet — point its action at Formspree / a Cloudflare
 * Worker / InsForge function when ready. Until then it's a styled shell.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

const hours = [
  { day: 'Monday',    time: '[TODO]' },
  { day: 'Tuesday',   time: '[TODO]' },
  { day: 'Wednesday', time: '[TODO]' },
  { day: 'Thursday',  time: '[TODO]' },
  { day: 'Friday',    time: '[TODO]' },
  { day: 'Saturday',  time: '[TODO]' },
  { day: 'Sunday',    time: '[TODO]' },
];
---

<BaseLayout
  title="Location & Contact"
  description="[TODO meta description — how to find Hidden Oak banya in Arambol, Goa.]"
>
  <Hero
    eyebrow="Find Us"
    title="Location & Contact"
    subtitle="[TODO hero subtitle — a line about Arambol and how to reach us.]"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
  />

  {/* ===== 1. MAP + ADDRESS ============================================= */}
  <section class="section">
    <div class="container loc-grid">
      <div class="loc-info">
        <p class="eyebrow">Address</p>
        <address class="address">
          [TODO street / landmark]<br />
          Arambol Beach<br />
          North Goa 403524<br />
          India
        </address>

        <p class="eyebrow" style="margin-top: var(--space-4);">Get in touch</p>
        <ul class="channels">
          <li>
            <span class="channels__label">Phone</span>
            <a href="tel:+91[TODO]">+91 [TODO]</a>
          </li>
          <li>
            <span class="channels__label">WhatsApp</span>
            <a href="https://wa.me/91[TODO]">+91 [TODO]</a>
          </li>
          <li>
            <span class="channels__label">Email</span>
            <a href="mailto:hello@hiddenoak.example">hello@hiddenoak.example</a>
          </li>
          <li>
            <span class="channels__label">Instagram</span>
            <a href="https://instagram.com">@hiddenoak.banya</a>
          </li>
        </ul>
      </div>

      <div class="loc-map">
        {/*
          TODO: paste the live Google Maps embed iframe here.
          Replace src with the share → embed map link for the Arambol address.
          Kept as a styled placeholder until the exact coords are confirmed.
        */}
        <div class="loc-map__placeholder">
          <span>[ Map embed · Google Maps iframe ]</span>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 2. DIRECTIONS =============================================== */}
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Getting here</p>
      <h2>[TODO heading — directions]</h2>
      <div class="directions">
        <article class="direction">
          <h3>From [TODO — nearest main town]</h3>
          <p>[TODO step-by-step — route, landmarks, travel time.]</p>
        </article>
        <article class="direction">
          <h3>From [TODO — airport / station]</h3>
          <p>[TODO step-by-step — taxi, bus, scooter options.]</p>
        </article>
        <article class="direction">
          <h3>On foot in Arambol</h3>
          <p>[TODO — how to find us once you're in Arambol village/beach.]</p>
        </article>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 3. OPENING HOURS ============================================ */}
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">When we're open</p>
      <h2>[TODO heading — opening hours]</h2>
      <ul class="hours">
        {
          hours.map((h) => (
            <li>
              <span class="hours__day">{h.day}</span>
              <span class="hours__time">{h.time}</span>
            </li>
          ))
        }
      </ul>
      <p class="hours-note">[TODO note — e.g. booking recommended, holidays.]</p>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 4. CONTACT FORM ============================================= */}
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Send a message</p>
      <h2>[TODO heading — contact form]</h2>
      <p class="lede">[TODO one-liner — what to expect when they hit send.]</p>

      {/*
        Static shell — no action/handler yet. Wire to Formspree, a Cloudflare
        Worker, or InsForge function when ready. Field names are kebab-case
        to map cleanly onto a backend.
      */}
      <form class="contact-form" method="POST" action="[TODO form endpoint]">
        <div class="field-row">
          <label class="field">
            <span class="field__label">Name</span>
            <input type="text" name="name" required placeholder="Your name" autocomplete="name" />
          </label>
          <label class="field">
            <span class="field__label">Email</span>
            <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
          </label>
        </div>
        <label class="field">
          <span class="field__label">Phone <span class="field__optional">(optional)</span></span>
          <input type="tel" name="phone" placeholder="+91 …" autocomplete="tel" />
        </label>
        <label class="field">
          <span class="field__label">Message</span>
          <textarea name="message" rows="5" required placeholder="[TODO — what would you like to know?]"></textarea>
        </label>
        <div class="contact-form__actions">
          <CTAButton href="#" variant="primary" size="md" class="contact-form__submit">
            Send message
          </CTAButton>
          <span class="contact-form__note">[TODO — typical response time.]</span>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .loc-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--space-5);
    align-items: start;
  }
  .address {
    font-style: normal;
    font-size: var(--text-md);
    color: var(--color-ink);
    line-height: var(--leading-normal);
  }
  .channels {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .channels li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .channels__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
    font-weight: var(--weight-semibold);
  }
  .channels a {
    font-size: var(--text-md);
    color: var(--birch-white);
  }
  .loc-map__placeholder {
    aspect-ratio: 4 / 3;
    background: var(--wood-smolder);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-subtle);
    font-size: var(--text-sm);
  }

  .narrow { max-width: var(--container-narrow); }
  .directions {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .direction h3 { font-size: var(--text-lg); margin-bottom: var(--space-1); }
  .direction p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }

  .hours {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
  }
  .hours li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .hours__day { color: var(--birch-white); font-weight: var(--weight-medium); }
  .hours__time { color: var(--color-ink-muted); }
  .hours-note {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }

  /* Contact form ------------------------------------------------------- */
  .contact-form {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .field__label {
    font-size: var(--text-sm);
    color: var(--color-ink);
    font-weight: var(--weight-medium);
  }
  .field__optional {
    font-weight: var(--weight-regular);
    color: var(--color-ink-subtle);
  }
  .contact-form input,
  .contact-form textarea {
    font: inherit;
    width: 100%;
    padding: var(--space-2) var(--space-3);
    background: var(--wood-smolder);
    color: var(--birch-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--color-ink-subtle);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--clay-terracotta);
    box-shadow: 0 0 0 3px rgba(181, 101, 29, 0.25);
  }
  .contact-form textarea { resize: vertical; min-height: 120px; }
  .contact-form__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-1);
  }
  :global(.contact-form__submit) { width: auto; }
  .contact-form__note {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }

  @media (max-width: 720px) {
    .loc-grid { grid-template-columns: 1fr; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>
