---
/**
 * Home — /
 *
 * Copy map (earthy/calm tone, short evocative sentences):
 *   1. Hero        — headline + subheadline
 *   2. What we offer — 2-3 sentence intro
 *   3. Why Hidden Oak — 4 short value points
 *   4. Pricing teaser
 *   5. Membership teaser
 *   6. Closing CTA — drives to /book
 *
 * [IMAGE: ...] placeholders render as visible labeled blocks in dev/preview
 * so you know what to shoot or source. Replace with <img> when photos are ready.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Hidden Oak"
  description="A traditional Russian banya in Arambol, Goa. Wood-fired steam, ice bath, and venik ritual — hidden among the palms. Sessions from ₹500. Book online."
>
  {/* ===== 1. HERO ======================================================
       Full-bleed background. Currently uses a themed SVG poster (placeholder).
       To use a looping video instead, drop a .mp4 in /public/video/ and add:
         video="/video/hero-loop.mp4"
       The poster stays as the mobile/reduced-motion fallback automatically.
  */}
  <Hero
    eyebrow="Russian Banya · Arambol, Goa"
    title="Steam and stillness, in the trees."
    subtitle="An old ritual of heat and cold. Wood walls, warm fire, and quiet — hidden among the palms of Arambol."
    poster="/images/hero/hero-poster.svg"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/the-banya', label: 'Read our story' }}
  />

  {/* ===== 2. WHAT WE OFFER ============================================= */}
  <section class="section" data-reveal>
    <div class="container offer">
      <div class="offer__copy">
        <p class="eyebrow">What we offer</p>
        <h2>Heat, cold, and the space between.</h2>
        <p class="lede">
          A traditional Russian banya, built from Goan earth and wood. Steam rooms warmed
          over hot stone, a cold plunge to follow, and time to rest. No rush. Just the slow,
          deep reset your body already knows how to want.
        </p>
        <CTAButton href="/services" variant="ghost" size="md">What you'll experience →</CTAButton>
      </div>
      <aside class="imgslot" aria-label="Image placeholder">
        <span>[IMAGE: Warm interior of the banya — wooden bench, steam rising, clay walls catching firelight. Landscape orientation.]</span>
      </aside>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 3. WHY HIDDEN OAK =========================================== */}
  <section class="section" data-reveal>
    <div class="container why">
      <div class="why__head">
        <p class="eyebrow">Why Hidden Oak</p>
        <h2>An old practice, kept honest.</h2>
        <p class="lede">
          We haven't reinvented the banya. We've just given it a home — and let the place do half the work.
        </p>
      </div>

      <div class="why__grid">
        <article class="why__point" data-reveal style="--reveal-delay: 0ms">
          <span class="why__num">01</span>
          <h3>Authentic Russian ritual</h3>
          <p>
            Steam over hot stone. Birch and oak venik. The cycle of heat, cold, and rest —
            the same one Russian villages have kept for a thousand years. Nothing added, nothing lost.
          </p>
        </article>

        <article class="why__point" data-reveal style="--reveal-delay: 80ms">
          <span class="why__num">02</span>
          <h3>A jungle setting</h3>
          <p>
            No tiles, no fluorescent light. Earth walls, local timber, palms overhead.
            You hear birds, not traffic. The banya sits inside the quiet — that's most of what we offer.
          </p>
        </article>

        <article class="why__point" data-reveal style="--reveal-delay: 160ms">
          <span class="why__num">03</span>
          <h3>The cold plunge</h3>
          <p>
            After the heat, the cold. It's the half everyone remembers — the sharp wake-up that makes
            the warmth that follows feel earned. Optional, always. Remarkable, usually.
          </p>
        </article>

        <article class="why__point" data-reveal style="--reveal-delay: 240ms">
          <span class="why__num">04</span>
          <h3>Community &amp; membership</h3>
          <p>
            A banya is better when it's yours. Members get regular slots, better rates, and a place
            that starts to feel like yours. Locals and long-stayers tend to stay.
          </p>
        </article>
      </div>

      <aside class="imgslot imgslot--wide" aria-label="Image placeholder">
        <span>[IMAGE: Exterior of the banya in its jungle setting — mud/clay walls, surrounded by palms and greenery, warm light from the doorway at dusk. Wide landscape.]</span>
      </aside>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 4. PRICING TEASER =========================================== */}
  <section class="section" data-reveal>
    <div class="container teaser teaser--pricing">
      <div class="teaser__copy">
        <p class="eyebrow">Pricing</p>
        <h2>Simple, honest pricing.</h2>
        <p class="lede">
          Pay per session, or come back often. No joining fees, no lock-in — just a price that makes sense.
        </p>
        <CTAButton href="/pricing" variant="ghost" size="md">See full pricing</CTAButton>
      </div>
      <aside class="teaser__card">
        <p class="teaser__card-eyebrow">From</p>
        <p class="teaser__card-price">₹[TODO]</p>
        <p class="teaser__card-unit">per session</p>
        <ul class="teaser__card-list">
          <li>Sauna &amp; steam room</li>
          <li>Cold plunge available</li>
          <li>Shower, towel &amp; tea included</li>
        </ul>
      </aside>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 5. MEMBERSHIP TEASER ======================================== */}
  <section class="section" data-reveal>
    <div class="container teaser teaser--member">
      <aside class="teaser__card teaser__card--feature">
        <p class="teaser__card-eyebrow">Membership</p>
        <h3>[TODO tier name]</h3>
        <p class="teaser__card-price">₹[TODO]<span class="teaser__card-unit">/ month</span></p>
        <ul class="teaser__card-list">
          <li>Four or more sessions a month</li>
          <li>Priority booking windows</li>
          <li>Discount on venik &amp; add-ons</li>
          <li>Bring a friend, once a month</li>
        </ul>
        <CTAButton href="/pricing" variant="primary" size="md">View memberships</CTAButton>
      </aside>
      <div class="teaser__copy">
        <p class="eyebrow">Become a regular</p>
        <h2>Make it yours.</h2>
        <p class="lede">
          For the people who keep coming back. Members get regular slots, better rates, and a place
          that starts to feel like theirs.
        </p>
        <CTAButton href="/pricing" variant="ghost" size="md">See membership options →</CTAButton>
      </div>
    </div>
  </section>

  {/* ===== 6. CLOSING CTA ============================================== */}
  <section class="section" data-reveal>
    <div class="container closing">
      <div class="closing__copy">
        <p class="eyebrow">Ready when you are</p>
        <h2>The best way to understand it is to step inside.</h2>
        <p class="lede">
          First-timers always welcome. We'll walk you through every step — the steam,
          the cold, the long quiet rest in between.
        </p>
        <div class="closing__actions">
          <CTAButton href="/book" variant="primary" size="lg">Book a Session</CTAButton>
          <CTAButton href="/location" variant="ghost" size="lg">Find us in Arambol</CTAButton>
        </div>
      </div>
      <aside class="imgslot" aria-label="Image placeholder">
        <span>[IMAGE: A guest mid-session — feet on a wooden bench, hands resting, steam softening the frame. Warm tones, calm mood. Portrait or square.]</span>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- what we offer ------------------------------------------------- */
  .offer {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .offer__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }
  .offer__copy h2 { max-width: 16ch; }

  /* ---- why hidden oak ----------------------------------------------- */
  .why {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .why__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--container-narrow);
  }
  .why__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .why__point {
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .why__num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-bold);
  }
  .why__point h3 {
    font-size: var(--text-lg);
    color: var(--birch-white);
  }
  .why__point p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }

  /* ---- teasers ------------------------------------------------------- */
  .teaser {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .teaser--member { grid-template-columns: 1fr 1.2fr; }
  .teaser__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }
  .teaser__copy h2 { max-width: 18ch; }

  .teaser__card {
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: flex-start;
  }
  .teaser__card--feature {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-glow);
  }
  .teaser__card-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-semibold);
  }
  .teaser__card-price {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--birch-white);
    line-height: 1;
  }
  .teaser__card-unit {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    margin-left: var(--space-1);
  }
  .teaser__card-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .teaser__card-list li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .teaser__card-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: var(--weight-bold);
  }

  /* ---- closing CTA -------------------------------------------------- */
  .closing {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .closing__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }
  .closing__copy h2 { max-width: 20ch; }
  .closing__actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  /* ---- image placeholder slots -------------------------------------- */
  /* Renders [IMAGE: ...] as a visible labeled block in dev/preview so you
     know what to shoot or source. Swap for an <img> when the photo is ready. */
  .imgslot {
    background: repeating-linear-gradient(
      45deg,
      var(--wood-smolder),
      var(--wood-smolder) 12px,
      var(--wood-burnt) 12px,
      var(--wood-burnt) 24px
    );
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    text-align: center;
  }
  .imgslot--wide { aspect-ratio: 21 / 9; }
  .imgslot span {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    background: rgba(13, 11, 9, 0.78);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    line-height: var(--leading-normal);
    max-width: 42ch;
  }

  /* ---- responsive --------------------------------------------------- */
  @media (max-width: 760px) {
    .offer,
    .teaser,
    .teaser--member,
    .closing { grid-template-columns: 1fr; }
  }
</style>
