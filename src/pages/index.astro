---
/**
 * Home — image-first cinematic landing.
 * Dual story: wood-fired heat + ice plunge, golden-hour photography.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

const journey = [
  {
    step: '01',
    icon: 'flame',
    title: 'Heat',
    tone: 'heat',
    body: 'Settle into the steam. Soft light, hot stone, and the quiet weight of warmth on your shoulders.',
    img: '/images/gallery/sauna-steam.jpg',
    alt: 'Steam rising in the wood-fired sauna',
  },
  {
    step: '02',
    icon: 'snowflake',
    title: 'Ice',
    tone: 'ice',
    body: 'The cold plunge — sharp, brief, clarifying. Optional always. Remarkable, usually.',
    img: '/images/gallery/ice-tub.jpg',
    alt: 'Cedar ice bath cold plunge tub',
  },
  {
    step: '03',
    icon: 'droplet',
    title: 'Rest',
    tone: 'rest',
    body: 'Tea, stillness, and time between rounds. This is where the body finishes what heat began.',
    img: '/images/gallery/community-rest.jpg',
    alt: 'Quiet rest area between banya rounds',
  },
  {
    step: '04',
    icon: 'branch',
    title: 'Repeat',
    tone: 'rest',
    body: 'Two or three rounds at your pace. Leave lighter than you arrived — that is the whole point.',
    img: '/images/gallery/detail-venik.jpg',
    alt: 'Venik birch branches for the ritual',
  },
];

const reasons = [
  {
    num: '01',
    title: 'Authentic ritual',
    body: 'Steam over hot stone. Venik. Heat, cold, rest — the same cycle Russian villages have kept for centuries.',
  },
  {
    num: '02',
    title: 'Jungle setting',
    body: 'Earth walls, local timber, palms overhead. You hear birds, not traffic. The quiet does half the work.',
  },
  {
    num: '03',
    title: 'Ice plunge',
    body: 'The part everyone remembers. Optional always — guided for first-timers. Heat opens; ice resets.',
  },
  {
    num: '04',
    title: 'Made for regulars',
    body: 'Memberships for locals and long-stayers. Better rates, a place that starts to feel like yours.',
  },
];
---

<BaseLayout
  title="Hidden Oak"
  description="A traditional Russian banya in Arambol, Goa. Wood-fired steam, ice bath, and venik ritual — hidden among the palms. Sessions from ₹500. Book online."
>
  <Hero
    eyebrow="Russian Banya · Arambol, Goa"
    title="Fire, ice & the quiet between."
    subtitle="A wood-fired banya of Goan earth and timber — steam that softens, ice that wakes, evenings that refuse to hurry."
    poster="/images/hero/hero-poster.jpg"
    dual={true}
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/gallery', label: 'See the space' }}
  />

  <div id="main-content"></div>

  {/* Stats strip */}
  <section class="stats-strip" aria-label="At a glance">
    <div class="container stats">
      {
        [
          { k: 'From', v: '₹500', s: 'per session' },
          { k: 'Heat + Ice', v: '75–90', s: 'minutes' },
          { k: 'Open', v: 'Daily', s: '6 PM – midnight' },
          { k: 'Where', v: 'Arambol', s: 'North Goa' },
        ].map((item, i) => (
          <div class="stats__item" data-reveal style={`--reveal-delay: ${i * 70}ms`}>
            <span class="stats__k">{item.k}</span>
            <span class="stats__v">{item.v}</span>
            <span class="stats__s">{item.s}</span>
          </div>
        ))
      }
    </div>
  </section>

  {/* Dual split: Heat | Ice — image first */}
  <section class="section dual-section" data-reveal>
    <div class="container">
      <div class="block-head block-head--center">
        <div class="dual-badge" data-reveal="fade">
          <span class="dual-badge__heat">
            <span class="deco-icon deco-icon--sm deco-icon--flame"></span> Heat
          </span>
          <span class="dual-badge__sep"></span>
          <span class="dual-badge__ice">
            <span class="deco-icon deco-icon--sm deco-icon--snowflake"></span> Ice
          </span>
        </div>
        <h2>Two elements. One ritual.</h2>
        <p class="lede lede--center">
          The banya is not only steam. It is the contrast — fire that opens, ice that closes,
          and the long breath between.
        </p>
      </div>

      <div class="dual-split">
        <a href="/services#sauna-steam" class="dual-card dual-card--heat" data-reveal>
          <div class="dual-card__media">
            <img
              src="/images/gallery/sauna-stove.jpg"
              alt="Wood stove glowing inside the Hidden Oak sauna"
              loading="lazy"
              decoding="async"
            />
            <span class="dual-card__tag">
              <span class="deco-icon deco-icon--sm deco-icon--flame"></span>
              The heat
            </span>
          </div>
          <div class="dual-card__body">
            <h3>Wood-fired steam</h3>
            <p>
              Hot stone, light steam, timber darkened by evenings of fire.
              Sit, breathe, and let the warmth work through you.
            </p>
            <span class="text-link">Into the parilka <span aria-hidden="true">→</span></span>
          </div>
        </a>

        <a href="/services#ice-bath" class="dual-card dual-card--ice" data-reveal style="--reveal-delay: 100ms">
          <div class="dual-card__media">
            <img
              src="/images/gallery/ice-tub.jpg"
              alt="Cedar ice bath cold plunge at Hidden Oak"
              loading="lazy"
              decoding="async"
            />
            <span class="dual-card__tag">
              <span class="deco-icon deco-icon--sm deco-icon--snowflake"></span>
              The ice
            </span>
          </div>
          <div class="dual-card__body">
            <h3>Cold plunge</h3>
            <p>
              Brief, sharp, unforgettable. Step from steam into ice —
              then back into heat with a clearer head.
            </p>
            <span class="text-link">Meet the kupel <span aria-hidden="true">→</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {/* Full-bleed visual band */}
  <section class="bleed-band" aria-label="Hidden Oak exterior" data-reveal="fade">
    <img
      src="/images/gallery/exterior-dusk.jpg"
      alt="Hidden Oak mud-and-wood banya at golden hour among palms"
      loading="lazy"
      decoding="async"
    />
    <div class="bleed-band__veil"></div>
    <div class="bleed-band__copy container">
      <p class="eyebrow" style="color: #ffc9a0;">Golden hour under the palms</p>
      <h2>Not a spa. A small world of earth, steam, and cold water.</h2>
      <a class="text-link text-link--light" href="/gallery">Walk the gallery <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  {/* Place mosaic */}
  <section class="section place-section" data-reveal>
    <div class="container place">
      <div class="place__intro">
        <p class="eyebrow">Made for this landscape</p>
        <h2>Clay walls. Ice water. Green all around.</h2>
        <p class="lede">
          Laterite earth holds the day’s warmth. Timber darkens with steam.
          Outside, the garden stays loud and green — a Goan home for a centuries-old cycle of heat and cold.
        </p>
        <a class="text-link" href="/the-banya">Our story <span aria-hidden="true">↗</span></a>
      </div>
      <div class="place__frames" aria-label="A visual glimpse of Hidden Oak">
        <figure class="place__frame place__frame--tall">
          <img src="/images/gallery/exterior-garden.jpg" alt="Garden greenery surrounding the banya" loading="lazy" decoding="async" />
          <figcaption>Garden quiet</figcaption>
        </figure>
        <figure class="place__frame place__frame--wide">
          <img src="/images/gallery/ice-detail.jpg" alt="Cold water surface of the ice plunge" loading="lazy" decoding="async" />
          <figcaption>Ice surface</figcaption>
        </figure>
        <figure class="place__frame place__frame--square">
          <img src="/images/gallery/detail-clay-wall.jpg" alt="Hand-finished clay wall detail" loading="lazy" decoding="async" />
          <figcaption>Earth &amp; texture</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* Journey — visual steps */}
  <section class="section section--band" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">The session</p>
        <h2>How a visit unfolds.</h2>
        <p class="lede">
          You are never rushed. Two or three rounds of heat, with rest — and ice if you want it —
          is the classic rhythm.
        </p>
      </div>
      <div class="journey">
        {
          journey.map((j, i) => (
            <article
              class:list={['journey__card', `journey__card--${j.tone}`]}
              data-reveal
              style={`--reveal-delay: ${i * 90}ms`}
            >
              <div class="journey__media">
                <img src={j.img} alt={j.alt} loading="lazy" decoding="async" />
              </div>
              <div class="journey__top">
                <span class:list={['icon-badge', j.tone === 'ice' && 'icon-badge--ice']} aria-hidden="true">
                  <span class={`deco-icon deco-icon--md deco-icon--${j.icon}`}></span>
                </span>
                <span class="journey__step">{j.step}</span>
              </div>
              <h3>{j.title}</h3>
              <p>{j.body}</p>
            </article>
          ))
        }
      </div>
      <div class="journey__cta">
        <CTAButton href="/services" variant="primary" size="md">Full experience guide</CTAButton>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* Why */}
  <section class="section section--jungle" data-reveal>
    <div class="container why">
      <div class="why__head">
        <p class="eyebrow">Why Hidden Oak</p>
        <h2>An old practice, kept honest.</h2>
        <p class="lede">
          We have not reinvented the banya. We have given it a home — fire and ice
          under the palms — and let the place do half the work.
        </p>
      </div>
      <div class="why__grid">
        {
          reasons.map((r, i) => (
            <article class="why__point surface-card" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
              <span class="why__num">{r.num}</span>
              <h3>{r.title}</h3>
              <p>{r.body}</p>
            </article>
          ))
        }
      </div>
      <div class="why__gallery" data-reveal>
        <figure class="img-panel why__shot">
          <img src="/images/gallery/sauna-bench.jpg" alt="Wooden benches in the steam room" loading="lazy" decoding="async" />
          <figcaption class="img-panel__caption">Steam benches</figcaption>
        </figure>
        <figure class="img-panel why__shot">
          <img src="/images/gallery/ice-tub.jpg" alt="Ice bath plunge tub" loading="lazy" decoding="async" />
          <figcaption class="img-panel__caption">Cold plunge</figcaption>
        </figure>
        <figure class="img-panel why__shot why__shot--wide">
          <img src="/images/gallery/exterior-approach.jpg" alt="Path approaching Hidden Oak through greenery" loading="lazy" decoding="async" />
          <figcaption class="img-panel__caption">The approach</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* Pricing + membership */}
  <section class="section" data-reveal>
    <div class="container price-grid">
      <article class="price-card surface-card" data-reveal>
        <p class="eyebrow">Walk-in</p>
        <h2>From ₹500</h2>
        <p class="price-card__sub">per session · ~75–90 min</p>
        <ul>
          <li>Sauna &amp; steam room</li>
          <li>Ice plunge available (+₹500)</li>
          <li>Shower, towel &amp; tea</li>
          <li>No joining fee</li>
        </ul>
        <CTAButton href="/pricing" variant="ghost" size="md">See full pricing</CTAButton>
      </article>

      <article class="price-card price-card--feature surface-card" data-reveal style="--reveal-delay: 100ms">
        <span class="price-card__badge">Most loved</span>
        <p class="eyebrow">Membership</p>
        <h2>Full Reset</h2>
        <p class="price-card__price">
          ₹7,000<span>/ month</span>
        </p>
        <ul>
          <li>8 sessions with ice bath</li>
          <li>Sauna, steam &amp; shower</li>
          <li>No lock-in · pause any time</li>
          <li>Built for regulars</li>
        </ul>
        <CTAButton href="/pricing" variant="primary" size="md">View memberships</CTAButton>
      </article>
    </div>
  </section>

  {/* Closing */}
  <section class="section closing-section" data-reveal>
    <div class="container closing">
      <div class="closing__visual">
        <img
          src="/images/gallery/sauna-steam.jpg"
          alt="Steam curling through warm light inside the sauna"
          loading="lazy"
          decoding="async"
        />
        <div class="closing__frost" aria-hidden="true"></div>
      </div>
      <div class="closing__copy">
        <p class="eyebrow">Ready when you are</p>
        <h2>Step into the heat. Meet the ice.</h2>
        <p class="lede">
          First-timers always welcome. We walk you through every step — the steam,
          the plunge, and the long quiet rest in between.
        </p>
        <div class="closing__actions">
          <CTAButton href="/book" variant="primary" size="lg">Book a Session</CTAButton>
          <CTAButton href="/location" variant="ghost" size="lg">Find us in Arambol</CTAButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Stats */
  .stats-strip {
    position: relative;
    margin-top: calc(-1 * var(--space-5));
    z-index: 5;
    padding-inline: var(--space-3);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg), 0 0 40px rgba(126, 182, 212, 0.12);
  }
  .stats__item {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    padding: var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: center;
    transition: background var(--duration-fast) var(--ease-soft);
  }
  .stats__item:hover { background: #fff; }
  .stats__k {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
  }
  .stats__v {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--forest-deep);
    font-weight: var(--weight-bold);
  }
  .stats__s {
    font-size: var(--text-xs);
    color: var(--color-gold);
  }

  .block-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--container-narrow);
    margin-bottom: var(--space-6);
  }
  .block-head--center {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }
  .lede--center { max-width: 48ch; margin-inline: auto; }

  /* Dual heat | ice */
  .dual-section { padding-top: var(--space-7); }
  .dual-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .dual-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-md);
    transition:
      transform var(--duration-fast) var(--ease-spring),
      box-shadow var(--duration-fast) var(--ease-soft),
      border-color var(--duration-fast) var(--ease-soft);
  }
  .dual-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }
  .dual-card--heat:hover { border-color: rgba(232, 93, 50, 0.35); }
  .dual-card--ice:hover { border-color: rgba(126, 182, 212, 0.5); }
  .dual-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--wood-charred);
  }
  .dual-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out),
      filter var(--duration-medium) var(--ease-soft);
  }
  .dual-card--heat .dual-card__media img {
    filter: brightness(1.08) saturate(1.1);
  }
  .dual-card--ice .dual-card__media img {
    filter: brightness(1.12) saturate(0.95) hue-rotate(6deg);
  }
  .dual-card:hover .dual-card__media img { transform: scale(1.06); }
  .dual-card__tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: #fff8ef;
    backdrop-filter: blur(10px);
    background: rgba(20, 14, 10, 0.4);
    border: 1px solid rgba(255, 248, 239, 0.2);
  }
  .dual-card--ice .dual-card__tag {
    background: rgba(30, 60, 80, 0.45);
  }
  .dual-card__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-4) var(--space-5);
  }
  .dual-card__body h3 {
    font-size: var(--text-xl);
    color: var(--forest-deep);
  }
  .dual-card__body p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }
  .dual-card--heat .dual-card__body .text-link { border-color: var(--hot-coal); }
  .dual-card--ice .dual-card__body .text-link { border-color: var(--ice-mid); }
  .dual-card--ice .dual-card__body .text-link span { color: var(--ice-deep); }

  /* Full-bleed band */
  .bleed-band {
    position: relative;
    min-height: clamp(360px, 58vh, 620px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-block: var(--space-4);
  }
  .bleed-band > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(1.14) saturate(1.12) contrast(1.04);
  }
  .bleed-band__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20, 14, 10, 0.1) 0%, rgba(20, 14, 10, 0.15) 40%, rgba(20, 14, 10, 0.72) 100%),
      radial-gradient(ellipse 50% 60% at 80% 70%, rgba(126, 182, 212, 0.15), transparent 60%);
  }
  .bleed-band__copy {
    position: relative;
    z-index: 2;
    padding-block: var(--space-7) var(--space-6);
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .bleed-band__copy h2 {
    color: #fff8ef;
    font-size: var(--text-3xl);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }
  .text-link--light {
    color: #fff8ef;
    border-color: rgba(255, 200, 150, 0.7);
  }
  .text-link--light:hover { color: #ffc9a0; }
  .text-link--light span { color: #9ec8e0; }

  /* Place mosaic */
  .place-section { padding-top: var(--space-7); }
  .place {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .place__intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .place__intro h2 { max-width: 14ch; }
  .place__frames {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-2);
    min-height: 460px;
  }
  .place__frame {
    position: relative;
    min-height: 0;
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }
  .place__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms var(--ease-out), filter 500ms var(--ease-soft);
  }
  .place__frame::after {
    content: '';
    position: absolute;
    inset: 40% 0 0;
    background: linear-gradient(transparent, rgba(30, 21, 16, 0.65));
    pointer-events: none;
  }
  .place__frame:hover img { transform: scale(1.07); filter: saturate(1.1) brightness(1.05); }
  .place__frame figcaption {
    position: absolute;
    left: var(--space-2);
    bottom: var(--space-2);
    z-index: 1;
    color: #fff8ef;
    font: 500 var(--text-xs) var(--font-sans);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .place__frame--tall {
    grid-row: span 2;
    border-radius: 120px 120px var(--radius-xl) var(--radius-xl);
  }
  .place__frame--wide { border-radius: var(--radius-xl) var(--radius-xl) 0 var(--radius-xl); }
  .place__frame--square { border-radius: 0 var(--radius-xl) var(--radius-xl) var(--radius-xl); }

  /* Journey with images */
  .journey {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .journey__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 0 0 var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-height: 100%;
    overflow: hidden;
    transition:
      transform var(--duration-fast) var(--ease-spring),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .journey__card:hover {
    transform: translateY(-6px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }
  .journey__card--ice:hover { border-color: rgba(126, 182, 212, 0.4); box-shadow: 0 12px 32px var(--ice-glow); }
  .journey__card--heat:hover { border-color: rgba(232, 93, 50, 0.3); }
  .journey__media {
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background: var(--wood-charred);
  }
  .journey__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .journey__card:hover .journey__media img { transform: scale(1.06); }
  .journey__card--ice .journey__media img {
    filter: brightness(1.1) saturate(0.95);
  }
  .journey__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: var(--space-4);
    margin-top: var(--space-1);
