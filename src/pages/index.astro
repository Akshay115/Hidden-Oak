---
/**
 * Home — cinematic landing for Hidden Oak Banya.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

const journey = [
  {
    step: '01',
    icon: 'flame',
    title: 'Heat',
    body: 'Settle into the steam. Soft light, hot stone, and the quiet weight of warmth on your shoulders.',
  },
  {
    step: '02',
    icon: 'snowflake',
    title: 'Cold',
    body: 'Optional ice plunge — sharp, brief, and clarifying. The contrast is half the ritual.',
  },
  {
    step: '03',
    icon: 'droplet',
    title: 'Rest',
    body: 'Tea, stillness, and time between rounds. This is where the body finishes what heat began.',
  },
  {
    step: '04',
    icon: 'branch',
    title: 'Repeat',
    body: 'Two or three rounds at your pace. Leave lighter than you arrived — that is the whole point.',
  },
];

const reasons = [
  {
    num: '01',
    title: 'Authentic ritual',
    body: 'Steam over hot stone. Venik. Heat, cold, rest — the same cycle Russian villages have kept for centuries.',
  },
  {
    num: '02',
    title: 'Jungle setting',
    body: 'Earth walls, local timber, palms overhead. You hear birds, not traffic. The quiet does half the work.',
  },
  {
    num: '03',
    title: 'Cold plunge',
    body: 'The part everyone remembers. Optional always — remarkable, usually. We guide first-timers gently.',
  },
  {
    num: '04',
    title: 'Made for regulars',
    body: 'Memberships for locals and long-stayers. Better rates, a place that starts to feel like yours.',
  },
];
---

<BaseLayout
  title="Hidden Oak"
  description="A traditional Russian banya in Arambol, Goa. Wood-fired steam, ice bath, and venik ritual — hidden among the palms. Sessions from ₹500. Book online."
>
  <Hero
    eyebrow="Russian Banya · Arambol, Goa"
    title="A ritual of fire, water & green."
    subtitle="A wood-fired banya made from Goan mud and timber — hidden in palms, softened by steam, and shaped around unhurried evenings."
    poster="/images/hero/hero-poster.jpg"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/the-banya', label: 'Read our story' }}
  />

  <div id="main-content"></div>

  {/* Stats strip */}
  <section class="stats-strip" aria-label="At a glance">
    <div class="container stats">
      {
        [
          { k: 'From', v: '₹500', s: 'per session' },
          { k: 'Sessions', v: '75–90', s: 'minutes' },
          { k: 'Open', v: 'Daily', s: '6 PM – midnight' },
          { k: 'Where', v: 'Arambol', s: 'North Goa' },
        ].map((item, i) => (
          <div class="stats__item" data-reveal style={`--reveal-delay: ${i * 70}ms`}>
            <span class="stats__k">{item.k}</span>
            <span class="stats__v">{item.v}</span>
            <span class="stats__s">{item.s}</span>
          </div>
        ))
      }
    </div>
  </section>

  {/* Offer */}
  <section class="section" data-reveal>
    <div class="container offer">
      <div class="offer__copy">
        <p class="eyebrow">What we offer</p>
        <h2>Heat, cold, and the space between.</h2>
        <p class="lede">
          A traditional Russian banya, built from Goan earth and wood. Steam rooms warmed over hot
          stone, a cold plunge to follow, and time to rest. No rush — just the deep reset your body
          already knows how to want.
        </p>
        <div class="offer__actions">
          <CTAButton href="/services" variant="ghost" size="md">What you'll experience →</CTAButton>
          <CTAButton href="/gallery" variant="ghost" size="md">See the space</CTAButton>
        </div>
      </div>
      <aside class="imgslot imgslot--filled" aria-label="Inside the sauna, wood stove and warm light">
        <img src="/images/gallery/sauna-stove.jpg" alt="The wood stove inside Hidden Oak's sauna, warm firelight on clay walls" loading="lazy" decoding="async" />
      </aside>
    </div>
  </section>

  {/* A visual pause — makes the place tangible before explaining the ritual. */}
  <section class="section place-section" data-reveal>
    <div class="container place">
      <div class="place__intro">
        <p class="eyebrow">Made for this landscape</p>
        <h2>Not a spa. A small world under the palms.</h2>
        <p class="lede">Clay holds the day’s warmth. Timber darkens with steam. Outside, the garden stays loud and green — a distinctly Goan setting for a centuries-old ritual.</p>
        <a class="text-link" href="/gallery">Walk through the space <span aria-hidden="true">↗</span></a>
      </div>
      <div class="place__frames" aria-label="A visual glimpse of Hidden Oak">
        <figure class="place__frame place__frame--tall">
          <img src="/images/gallery/exterior-garden.jpg" alt="Garden greenery surrounding the Hidden Oak banya" loading="lazy" decoding="async" />
          <figcaption>Garden quiet</figcaption>
        </figure>
        <figure class="place__frame place__frame--wide">
          <img src="/images/gallery/detail-clay-wall.jpg" alt="Warm hand-finished clay wall detail" loading="lazy" decoding="async" />
          <figcaption>Earth &amp; texture</figcaption>
        </figure>
        <figure class="place__frame place__frame--square">
          <img src="/images/gallery/detail-wood-grain.jpg" alt="Wood grain detail inside the banya" loading="lazy" decoding="async" />
          <figcaption>Dark timber</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* Journey */}
  <section class="section section--band" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">The session</p>
        <h2>How a visit unfolds.</h2>
        <p class="lede">
          You are never rushed. Two or three rounds of heat, with rest — and cold if you want it —
          is the classic rhythm.
        </p>
      </div>
      <div class="journey">
        {
          journey.map((j, i) => (
            <article
              class="journey__card"
              data-reveal
              style={`--reveal-delay: ${i * 90}ms`}
            >
              <div class="journey__top">
                <span class="icon-badge" aria-hidden="true">
                  <span class={`deco-icon deco-icon--md deco-icon--${j.icon}`}></span>
                </span>
                <span class="journey__step">{j.step}</span>
              </div>
              <h3>{j.title}</h3>
              <p>{j.body}</p>
            </article>
          ))
        }
      </div>
      <div class="journey__cta">
        <CTAButton href="/services" variant="primary" size="md">Full experience guide</CTAButton>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* Why */}
  <section class="section section--jungle" data-reveal>
    <div class="container why">
      <div class="why__head">
        <p class="eyebrow">Why Hidden Oak</p>
        <h2>An old practice, kept honest.</h2>
        <p class="lede">
          We have not reinvented the banya. We have given it a home — and let the place do half the
          work.
        </p>
      </div>
      <div class="why__grid">
        {
          reasons.map((r, i) => (
            <article class="why__point" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
              <span class="why__num">{r.num}</span>
              <h3>{r.title}</h3>
              <p>{r.body}</p>
            </article>
          ))
        }
      </div>
      <aside class="imgslot imgslot--wide imgslot--filled" aria-label="Exterior at dusk">
        <img src="/images/gallery/exterior-dusk.jpg" alt="Hidden Oak's mud-and-wood banya at dusk, palms silhouetted against a warm sky" loading="lazy" decoding="async" />
      </aside>
    </div>
  </section>

  <SectionDivider />

  {/* Pricing + membership */}
  <section class="section" data-reveal>
    <div class="container price-grid">
      <article class="price-card" data-reveal>
        <p class="eyebrow">Walk-in</p>
        <h2>From ₹500</h2>
        <p class="price-card__sub">per session · ~75–90 min</p>
        <ul>
          <li>Sauna &amp; steam room</li>
          <li>Cold plunge available (+₹500)</li>
          <li>Shower, towel &amp; tea</li>
          <li>No joining fee</li>
        </ul>
        <CTAButton href="/pricing" variant="ghost" size="md">See full pricing</CTAButton>
      </article>

      <article class="price-card price-card--feature" data-reveal style="--reveal-delay: 100ms">
        <span class="price-card__badge">Most loved</span>
        <p class="eyebrow">Membership</p>
        <h2>Full Reset</h2>
        <p class="price-card__price">
          ₹7,000<span>/ month</span>
        </p>
        <ul>
          <li>8 sessions with ice bath</li>
          <li>Sauna, steam &amp; shower</li>
          <li>No lock-in · pause any time</li>
          <li>Built for regulars</li>
        </ul>
        <CTAButton href="/pricing" variant="primary" size="md">View memberships</CTAButton>
      </article>
    </div>
  </section>

  {/* Closing */}
  <section class="section closing-section" data-reveal>
    <div class="container closing glass-card">
      <div class="closing__copy">
        <p class="eyebrow">Ready when you are</p>
        <h2>The best way to understand it is to step inside.</h2>
        <p class="lede">
          First-timers always welcome. We will walk you through every step — the steam, the cold,
          and the long quiet rest in between.
        </p>
        <div class="closing__actions">
          <CTAButton href="/book" variant="primary" size="lg">Book a Session</CTAButton>
          <CTAButton href="/location" variant="ghost" size="lg">Find us in Arambol</CTAButton>
        </div>
      </div>
      <aside class="imgslot imgslot--closing imgslot--filled" aria-label="Steam rising in the sauna">
        <img src="/images/gallery/sauna-steam.jpg" alt="Steam curling through warm light inside the Hidden Oak sauna" loading="lazy" decoding="async" />
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* Stats */
  .stats-strip {
    position: relative;
    margin-top: calc(-1 * var(--space-5));
    z-index: 5;
    padding-inline: var(--space-3);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg), var(--shadow-glow-soft);
  }
  .stats__item {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    padding: var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: center;
    transition: background var(--duration-fast) var(--ease-soft);
  }
  .stats__item:hover {
    background: rgba(255, 255, 255, 0.95);
  }
  .stats__k {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--color-ink-subtle);
  }
  .stats__v {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--forest-deep);
    font-weight: var(--weight-bold);
  }
  .stats__s {
    font-size: var(--text-xs);
    color: var(--color-gold);
  }

  .block-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--container-narrow);
    margin-bottom: var(--space-6);
  }

  .place-section { padding-top: var(--space-7); }
  .place {
    display: grid;
    grid-template-columns: .8fr 1.2fr;
    gap: clamp(2rem, 7vw, 7rem);
    align-items: center;
  }
  .place__intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .place__intro h2 { max-width: 12ch; }
  .text-link {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    color: var(--birch-white);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: .01em;
    border-bottom: 1px solid var(--gold-ember);
    padding-bottom: .35rem;
  }
  .text-link span { color: var(--hot-coal-bright); transition: transform var(--transition-fast); }
  .text-link:hover span { transform: translate(2px, -2px); }
  .place__frames {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-2);
    min-height: 460px;
  }
  .place__frame {
    position: relative;
    min-height: 0;
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }
  .place__frame img { width: 100%; height: 100%; object-fit: cover; transition: transform 900ms var(--ease-out), filter 500ms var(--ease-soft); }
  .place__frame::after { content: ''; position: absolute; inset: 40% 0 0; background: linear-gradient(transparent, rgba(30, 21, 16, 0.7)); pointer-events: none; }
  .place__frame:hover img { transform: scale(1.07); filter: saturate(1.12); }
  .place__frame figcaption { position: absolute; left: var(--space-2); bottom: var(--space-2); z-index: 1; color: var(--birch-white); font: 500 var(--text-xs) var(--font-sans); letter-spacing: var(--tracking-caps); text-transform: uppercase; }
  .place__frame--tall { grid-row: span 2; border-radius: 120px 120px var(--radius-xl) var(--radius-xl); }
  .place__frame--wide { border-radius: var(--radius-xl) var(--radius-xl) 0 var(--radius-xl); }
  .place__frame--square { border-radius: 0 var(--radius-xl) var(--radius-xl) var(--radius-xl); }

  /* Offer */
  .offer {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .offer__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .offer__copy h2 { max-width: 14ch; }
  .offer__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  /* Journey */
  .journey {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .journey__card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-height: 100%;
    transition:
      transform var(--duration-fast) var(--ease-spring),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .journey__card:hover {
    transform: translateY(-6px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md), var(--shadow-glow-soft);
  }
  .journey__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .journey__step {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gold);
    letter-spacing: 0.08em;
  }
  .journey__card h3 {
    font-size: var(--text-xl);
    color: var(--forest-deep);
  }
  .journey__card p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }
  .journey__cta {
    margin-top: var(--space-5);
    display: flex;
    justify-content: center;
  }

  /* Why */
  .why {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .why__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--container-narrow);
  }
  .why__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-3);
  }
  .why__point {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition:
      transform var(--duration-fast) var(--ease-spring),
      border-color var(--duration-fast) var(--ease-soft),
      box-shadow var(--duration-fast) var(--ease-soft);
  }
  .why__point:hover {
    transform: translateY(-4px);
    border-color: rgba(61, 90, 72, 0.25);
    box-shadow: var(--shadow-md);
  }
  .why__num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-bold);
  }
  .why__point h3 {
    font-size: var(--text-lg);
    color: var(--forest-deep);
  }
  .why__point p {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  /* Price grid */
  .price-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .price-card {
    position: relative;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    box-shadow: var(--shadow-md);
  }
  .price-card--feature {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(61, 90, 72, 0.08), transparent 60%),
      var(--color-bg-elevated);
  }
  .price-card__badge {
    position: absolute;
    top: calc(-1 * var(--space-2));
    left: var(--space-5);
    background: var(--clay-deep);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
  }
  .price-card h2 {
    font-size: var(--text-3xl);
    color: var(--forest-deep);
  }
  .price-card__sub,
  .price-card__price span {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }
  .price-card__price {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--forest-deep);
  }
  .price-card ul {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .price-card li {
    position: relative;
    padding-left: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .price-card li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #7a9a6e;
    font-weight: bold;
  }

  /* Closing */
  .closing-section { padding-bottom: var(--space-8); }
  .closing {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-6);
  }
  .closing__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .closing__copy h2 { max-width: 18ch; }
  .closing__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  /* Image placeholders (real photos still pending) */
  .imgslot {
    position: relative;
    background:
      linear-gradient(145deg, rgba(63, 45, 32, 0.9), rgba(30, 21, 16, 0.95)),
      var(--img-ornament);
    background-size: auto, 280px;
    background-blend-mode: normal, soft-light;
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-xl);
    aspect-ratio: 4 / 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    text-align: center;
    overflow: hidden;
  }
  .imgslot--wide { aspect-ratio: 21 / 9; }
  .imgslot--closing { aspect-ratio: 1; min-height: 220px; }
  .imgslot--filled {
    border: 1px solid var(--color-border);
    padding: 0;
    background: var(--wood-charred);
  }
  .imgslot--filled img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .imgslot--filled:hover img {
    transform: scale(1.035);
  }
  .imgslot__glow {
    position: absolute;
    width: 60%;
    height: 60%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 93, 50, 0.18), transparent 70%);
    filter: blur(20px);
    animation: ambient-breathe 8s ease-in-out infinite alternate;
  }
  .imgslot__icon {
    color: var(--hot-coal-bright);
    opacity: 0.55;
    margin-bottom: var(--space-2);
    position: relative;
  }
  .imgslot span:last-child {
    position: relative;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-subtle);
    background: rgba(13, 11, 9, 0.72);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    line-height: var(--leading-normal);
    max-width: 42ch;
  }

  @media (max-width: 900px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .journey { grid-template-columns: repeat(2, 1fr); }
    .price-grid { grid-template-columns: 1fr; }
    .offer,
    .closing,
    .place { grid-template-columns: 1fr; }
    .place__frames { max-width: 640px; width: 100%; }
  }
  @media (max-width: 520px) {
    .stats { grid-template-columns: 1fr 1fr; }
    .journey { grid-template-columns: 1fr; }
    .stats-strip { margin-top: calc(-1 * var(--space-3)); }
    .place__frames { min-height: 340px; }
    .place__frame--tall { border-radius: 72px 72px var(--radius-lg) var(--radius-lg); }
  }
</style>
