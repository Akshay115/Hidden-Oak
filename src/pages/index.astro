---
/**
 * Home — /home
 * Sections: hero, quick intro, pricing teaser, membership teaser, booking CTA, location teaser.
 * Copy is placeholder only — headings + [TODO] markers, no real prose yet.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout title="Hidden Oak">
  {/* ===== 1. HERO ====================================================== */}
  <Hero
    eyebrow="Russian Banya · Arambol, Goa"
    title="Hidden Oak"
    subtitle="[TODO hero subtitle — one-line promise of the banya experience.]"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
    secondaryCta={{ href: '/the-banya', label: 'What is a Banya?' }}
  />

  {/* ===== 2. QUICK INTRO =============================================== */}
  <section class="section">
    <div class="container intro">
      <p class="eyebrow">Welcome</p>
      <h2>[TODO intro heading]</h2>
      <p class="lede">
        [TODO 2–3 sentence intro — what Hidden Oak is, the Indian-Russian fusion angle,
        and an invitation to keep reading.]
      </p>
      <CTAButton href="/services" variant="ghost" size="md">What you'll experience →</CTAButton>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 3. PRICING TEASER ============================================ */}
  <section class="section">
    <div class="container teaser teaser--pricing">
      <div class="teaser__copy">
        <p class="eyebrow">Pricing</p>
        <h2>[TODO pricing teaser heading]</h2>
        <p class="lede">
          [TODO one-liner about walk-in sessions, with a link to full pricing.]
        </p>
        <CTAButton href="/pricing" variant="ghost" size="md">See full pricing</CTAButton>
      </div>
      <aside class="teaser__card">
        <p class="teaser__card-eyebrow">From</p>
        <p class="teaser__card-price">₹[TODO]</p>
        <p class="teaser__card-unit">per session</p>
        <ul class="teaser__card-list">
          <li>[TODO included item]</li>
          <li>[TODO included item]</li>
          <li>[TODO included item]</li>
        </ul>
      </aside>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 4. MEMBERSHIP TEASER ========================================= */}
  <section class="section">
    <div class="container teaser teaser--member">
      <aside class="teaser__card teaser__card--feature">
        <p class="teaser__card-eyebrow">Membership</p>
        <h3>[TODO membership tier name]</h3>
        <p class="teaser__card-price">₹[TODO]<span class="teaser__card-unit">/ month</span></p>
        <ul class="teaser__card-list">
          <li>[TODO member perk]</li>
          <li>[TODO member perk]</li>
          <li>[TODO member perk]</li>
        </ul>
        <CTAButton href="/pricing" variant="primary" size="md">View memberships</CTAButton>
      </aside>
      <div class="teaser__copy">
        <p class="eyebrow">Become a regular</p>
        <h2>[TODO membership teaser heading]</h2>
        <p class="lede">
          [TODO one-liner on why membership pays off for locals / long-stay visitors.]
        </p>
      </div>
    </div>
  </section>

  {/* ===== 5. BOOKING CTA =============================================== */}
  <section class="section">
    <div class="container cta-band">
      <div>
        <p class="eyebrow">Ready when you are</p>
        <h2>[TODO booking CTA heading]</h2>
        <p class="lede">[TODO one-liner pointing to the scheduler.]</p>
      </div>
      <CTAButton href="/book" variant="primary" size="lg">Book Now</CTAButton>
    </div>
  </section>

  {/* ===== 6. LOCATION TEASER =========================================== */}
  <section class="section">
    <div class="container teaser teaser--location">
      <div class="teaser__copy">
        <p class="eyebrow">Where to find us</p>
        <h2>[TODO location teaser heading]</h2>
        <p class="lede">
          [TODO one-liner — Arambol, Goa; a note on setting / how to reach us.]
        </p>
        <CTAButton href="/location" variant="ghost" size="md">Get directions</CTAButton>
      </div>
      <aside class="teaser__map">
        <div class="teaser__map-placeholder">[Map preview · /location]</div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    max-width: var(--container-narrow);
  }

  /* Teaser layout: copy + card, alternating sides */
  .teaser {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .teaser--member { grid-template-columns: 1fr 1.2fr; }
  .teaser__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }
  .teaser__copy h2 { max-width: 18ch; }

  .teaser__card {
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: flex-start;
  }
  .teaser__card--feature {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-glow);
  }
  .teaser__card-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--hot-coal);
    font-weight: var(--weight-semibold);
  }
  .teaser__card-price {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--birch-white);
    line-height: 1;
  }
  .teaser__card-unit {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    margin-left: var(--space-1);
  }
  .teaser__card-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 var(--space-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .teaser__card-list li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .teaser__card-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--forest-light);
    font-weight: var(--weight-bold);
  }

  .teaser__map-placeholder {
    aspect-ratio: 4 / 3;
    background: var(--wood-smolder);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-subtle);
    font-size: var(--text-sm);
  }

  .cta-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  @media (max-width: 720px) {
    .teaser,
    .teaser--member { grid-template-columns: 1fr; }
    .cta-band { flex-direction: column; align-items: flex-start; }
  }
</style>
