---
/**
 * Pricing & Memberships — /pricing
 * Walk-in prices + membership tiers. Exact numbers supplied by owner — using
 * ₹ placeholders so the layout is ready to drop figures into.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

// Walk-in / single-session options.
const walkIns = [
  {
    name: '[TODO name — e.g. Drop-in Session]',
    price: '₹[TODO]',
    cadence: 'single visit',
    features: ['[TODO included]', '[TODO included]', '[TODO included]'],
  },
  {
    name: '[TODO name — e.g. Full Cycle]',
    price: '₹[TODO]',
    cadence: 'single visit',
    features: ['[TODO included]', '[TODO included]', '[TODO included]'],
  },
];

// Membership tiers — featured one gets the highlight treatment.
const tiers = [
  {
    name: '[TODO tier name]',
    price: '₹[TODO]',
    cadence: 'per month',
    features: ['[TODO perk]', '[TODO perk]', '[TODO perk]'],
    featured: false,
  },
  {
    name: '[TODO tier name — featured]',
    price: '₹[TODO]',
    cadence: 'per month',
    features: ['[TODO perk]', '[TODO perk]', '[TODO perk]', '[TODO perk]'],
    featured: true,
  },
  {
    name: '[TODO tier name]',
    price: '₹[TODO]',
    cadence: 'per month',
    features: ['[TODO perk]', '[TODO perk]', '[TODO perk]'],
    featured: false,
  },
];
---

<BaseLayout
  title="Pricing & Memberships"
  description="[TODO meta description — Hidden Oak banya session and membership prices in Arambol, Goa.]"
>
  <Hero
    eyebrow="Pricing"
    title="Pricing & Memberships"
    subtitle="[TODO hero subtitle — simple honest pricing, no joining fee.]"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
  />

  {/* ===== 1. WALK-IN / SINGLE SESSION ================================== */}
  <section class="section">
    <div class="container">
      <p class="eyebrow">Walk-in</p>
      <h2>[TODO heading — pay per session]</h2>
      <p class="lede">[TODO one-liner — no commitment, just turn up.]</p>
      <p class="block-aside">
        Not sure what's included? <a href="/services">See what's included →</a>
      </p>

      <div class="walkins">
        {
          walkIns.map((w) => (
            <article class="price-card">
              <h3>{w.name}</h3>
              <div class="price-card__price">
                <span class="price-card__amount">{w.price}</span>
                <span class="price-card__cadence">{w.cadence}</span>
              </div>
              <ul>
                {w.features.map((f) => <li>{f}</li>)}
              </ul>
              <CTAButton href="/book" variant="ghost" size="md" class="price-card__cta">Book this</CTAButton>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 2. MEMBERSHIPS ============================================== */}
  <section class="section">
    <div class="container">
      <p class="eyebrow">Memberships</p>
      <h2>[TODO heading — become a regular]</h2>
      <p class="lede">[TODO one-liner — for locals and long-stay visitors.]</p>

      <div class="tiers">
        {
          tiers.map((t) => (
            <article class:list={['price-card', 'price-card--tier', { 'price-card--featured': t.featured }]}>
              {t.featured && <span class="price-card__badge">Most popular</span>}
              <h3>{t.name}</h3>
              <div class="price-card__price">
                <span class="price-card__amount">{t.price}</span>
                <span class="price-card__cadence">{t.cadence}</span>
              </div>
              <ul>
                {t.features.map((f) => <li>{f}</li>)}
              </ul>
              <CTAButton
                href="/book"
                variant={t.featured ? 'primary' : 'ghost'}
                size="md"
                class="price-card__cta"
              >
                {t.featured ? 'Join now' : 'Choose'}
              </CTAButton>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ===== 3. GOOD TO KNOW ============================================= */}
  <section class="section">
    <div class="container note">
      <p class="eyebrow">Good to know</p>
      <h2>[TODO heading — a few details]</h2>
      <ul>
        <li>[TODO policy — e.g. sessions by appointment only]</li>
        <li>[TODO policy — e.g. 24h cancellation]</li>
        <li>[TODO policy — e.g. gift vouchers available]</li>
        <li>[TODO policy — e.g. health contraindications note]</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .walkins,
  .tiers {
    margin-top: var(--space-5);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    align-items: stretch;
  }
  .price-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--wood-burnt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }
  .price-card--featured {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-glow);
  }
  .price-card__badge {
    position: absolute;
    top: calc(-1 * var(--space-2));
    left: var(--space-4);
    background: var(--hot-coal);
    color: var(--birch-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
  }
  .price-card h3 {
    font-family: var(--font-serif);
    color: var(--birch-white);
  }
  .price-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .price-card__amount {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--birch-white);
  }
  .price-card__cadence {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }
  .price-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .price-card li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .price-card li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--forest-light);
    font-weight: var(--weight-bold);
  }
  .price-card__cta { margin-top: auto; width: 100%; }

  .block-aside {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }
  .block-aside a { font-weight: var(--weight-semibold); }

  .note ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .note li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
  }
  .note li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--clay-light);
  }
</style>
