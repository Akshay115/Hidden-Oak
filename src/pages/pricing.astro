---
/**
 * Pricing & Memberships — /pricing
 *
 * Two sections:
 *   1. Walk-in sessions (2 cards)
 *   2. Monthly memberships (4 cards, "Full Reset" highlighted)
 *
 * Every card links to /book. Wood/clay styling from design tokens.
 * Inbound link to /services ("See what's included →") sits above the walk-in
 * cards so visitors understand what they're paying for.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTAButton from '../components/CTAButton.astro';

// --- Section 1: Walk-in sessions ----------------------------------------
const walkIns = [
  {
    name: 'Without Ice Bath',
    price: '₹500',
    cadence: 'per session',
    duration: '~75 min',
    icon: 'flame' as const,
    features: [
      'Sauna & steam room',
      'Two or three heat rounds',
      'Shower included',
      'Rest area with tea',
    ],
    note: 'The full banya cycle, without the cold plunge.',
  },
  {
    name: 'With Ice Bath',
    price: '₹1000',
    cadence: 'per session',
    duration: '~90 min',
    icon: 'snowflake' as const,
    features: [
      'Everything in the base session',
      'Cold plunge between rounds',
      'Guided first plunge if you want it',
      'Shower included',
    ],
    note: 'Heat and cold together — the traditional full cycle.',
    featured: true,
  },
];

// --- Section 2: Monthly memberships -------------------------------------
// sessions = short differentiator under the price (not repeated in the list)
const tiers = [
  {
    name: 'Steam Only',
    price: '₹3,500',
    cadence: '/ month',
    sessions: '8 sessions',
    icon: 'flame' as const,
    features: [
      'Sauna & steam room',
      'No ice bath access',
      'Shower & tea included',
      'Cancel any time',
    ],
    featured: false,
    cta: 'Choose Steam Only',
  },
  {
    name: 'Full Reset',
    price: '₹7,000',
    cadence: '/ month',
    sessions: '8 sessions · ice included',
    icon: 'branch' as const,
    features: [
      'Sauna & steam room',
      'Ice bath every visit',
      'Shower & tea included',
      'Cancel any time',
    ],
    featured: true,
    cta: 'Choose Full Reset',
  },
  {
    name: 'Unlimited Local',
    price: '₹15,000',
    cadence: '/ month',
    sessions: 'Unlimited · 1 / day',
    icon: 'droplet' as const,
    features: [
      'Sauna, steam & ice bath',
      'Fair-use cap of 1 / day',
      'Shower & tea included',
      'Built for locals',
    ],
    featured: false,
    cta: 'Choose Unlimited',
  },
  {
    name: 'Couple’s',
    price: '₹12,000',
    cadence: '/ month',
    sessions: '8 each · for two',
    icon: 'branch' as const,
    features: [
      '8 sessions each (2 people)',
      'Sauna, steam & ice bath',
      'Shower & tea included',
      'Cancel any time',
    ],
    featured: false,
    cta: 'Choose Couple’s',
  },
];
---

<BaseLayout
  title="Pricing & Memberships"
  description="Hidden Oak banya pricing — walk-in sessions from ₹500, monthly memberships from ₹3,500. Sauna, steam, ice bath, and shower. Arambol, Goa."
>
  <Hero
    compact
    dual
    eyebrow="Pricing"
    title="Pricing & Memberships"
    subtitle="Pay per visit, or make it a habit. No joining fees, no lock-in — just steam, ice, and rest."
    poster="/images/gallery/ice-detail.jpg"
    primaryCta={{ href: '/book', label: 'Book a Session' }}
  />

  {/* ============================================================
       1. WALK-IN SESSIONS
  ============================================================ */}
  <section class="section" id="walk-in" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">Walk-in</p>
        <h2>Pay per session</h2>
        <p class="lede">
          Coming once, or passing through? Both options include the full sauna and
          steam experience. The only difference is the ice bath.
        </p>
        <p class="block-aside">
          Not sure what's included? <a href="/services">See what's included →</a>
        </p>
      </div>

      <div class="cards cards--walkin">
        {
          walkIns.map((w, i) => (
            <article
              class:list={['card', 'card--walkin', { 'card--featured': w.featured }]}
              data-reveal
              style={`--reveal-delay: ${i * 80}ms`}
            >
              {w.featured && <span class="card__badge">Most popular</span>}
              <header class="card__header">
                <span
                  class:list={['card__icon', 'deco-icon', 'deco-icon--md', `deco-icon--${w.icon}`]}
                  aria-hidden="true"
                ></span>
                <h3>{w.name}</h3>
              </header>
              <div class="card__price">
                <span class="card__amount">{w.price}</span>
                <span class="card__cadence">{w.cadence}</span>
              </div>
              <p class="card__duration">{w.duration}</p>
              <ul class="card__list">
                {w.features.map((f) => <li>{f}</li>)}
              </ul>
              <p class="card__note">{w.note}</p>
              <div class="card__footer">
                <CTAButton
                  href="/book"
                  variant={w.featured ? 'primary' : 'ghost'}
                  size="md"
                  class="card__cta"
                >
                  Book this session
                </CTAButton>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       2. MONTHLY MEMBERSHIPS
  ============================================================ */}
  <section class="section" id="memberships" data-reveal>
    <div class="container">
      <div class="block-head">
        <p class="eyebrow">Memberships</p>
        <h2>Come back often</h2>
        <p class="lede">
          For locals and long-stayers. Members get regular slots, better rates,
          and a place that starts to feel like theirs. Cancel any time — no lock-in.
        </p>
      </div>

      <div class="cards cards--tiers">
        {
          tiers.map((t, i) => (
            <article
              class:list={['card', 'card--tier', { 'card--featured': t.featured }]}
              data-reveal
              style={`--reveal-delay: ${i * 80}ms`}
            >
              {t.featured && <span class="card__badge">Recommended</span>}
              <header class="card__header">
                <span
                  class:list={['card__icon', 'deco-icon', 'deco-icon--md', `deco-icon--${t.icon}`]}
                  aria-hidden="true"
                ></span>
                <h3>{t.name}</h3>
              </header>
              <div class="card__price">
                <span class="card__amount">{t.price}</span>
                <span class="card__cadence">{t.cadence}</span>
              </div>
              <p class="card__sessions">{t.sessions}</p>
              <ul class="card__list">
                {t.features.map((f) => <li>{f}</li>)}
              </ul>
              <div class="card__footer">
                <CTAButton
                  href="/book"
                  variant={t.featured ? 'primary' : 'ghost'}
                  size="md"
                  class="card__cta"
                >
                  {t.cta}
                </CTAButton>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ============================================================
       3. GOOD TO KNOW
  ============================================================ */}
  <section class="section" id="good-to-know" data-reveal>
    <div class="container narrow">
      <div class="block-head">
        <p class="eyebrow">Good to know</p>
        <h2>A few details</h2>
      </div>
      <ul class="policies">
        <li>
          <span class="policies__label">Booking ahead</span>
          Sessions are by appointment only — please book before you come. Same-day
          slots are sometimes available depending on the day.
        </li>
        <li>
          <span class="policies__label">Cancellations</span>
          Free to cancel or reschedule up to 24 hours before your session. Inside
          that window, we hold the fee.
        </li>
        <li>
          <span class="policies__label">Memberships</span>
          Monthly, billed upfront. No joining fee and no lock-in — pause or cancel
          with a week's notice.
        </li>
        <li>
          <span class="policies__label">Fair-use cap</span>
          The Unlimited Local membership allows one session per day, per member.
        </li>
        <li>
          <span class="policies__label">Health first</span>
          Banya isn't for everyone. If you're pregnant, have a heart condition or
          blood pressure issues, or are managing a medical condition, please check
          with your doctor before booking.
        </li>
        <li>
          <span class="policies__label">Gift vouchers</span>
          Available for single sessions or memberships — just ask us.
        </li>
      </ul>

      <div class="need-help">
        <p>Not sure which option fits?</p>
        <a href="/location">Ask us — we'll help you choose →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .block-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-5);
    max-width: var(--container-narrow);
  }
  .block-head h2 { max-width: 18ch; }
  .block-aside {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }
  .block-aside a { font-weight: var(--weight-semibold); }
  .narrow { max-width: var(--container-narrow); }

  /* ---- cards grid (shared) ------------------------------------------ */
  .cards {
    display: grid;
    gap: var(--space-4);
    align-items: stretch;
  }
  .cards--walkin {
    grid-template-columns: repeat(2, 1fr);
    max-width: 760px;
    padding-top: var(--space-3);
  }
  .card--walkin .card__header {
    min-height: 4.5rem;
  }
  /* 4 equal membership columns on wide screens; never orphan a card */
  .cards--tiers {
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    /* Room for the "Recommended" badge that sits above the card edge */
    padding-top: var(--space-3);
  }

  /* ---- card ---------------------------------------------------------- */
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-4) var(--space-4);
    box-shadow: var(--shadow-sm);
    min-width: 0; /* prevent grid blowout from long words */
    transition: transform var(--transition-base), border-color var(--transition-base),
      box-shadow var(--transition-base);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }

  .card--featured {
    border-color: var(--clay-terracotta);
    box-shadow: var(--shadow-glow), var(--shadow-md);
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%, rgba(126, 182, 212, 0.1), transparent 55%),
      var(--color-bg-elevated);
  }
  .card--featured:hover {
    border-color: var(--clay-light);
    box-shadow: var(--shadow-glow), var(--shadow-lg);
  }

  .card__badge {
    position: absolute;
    top: calc(-1 * var(--space-2));
    left: 50%;
    transform: translateX(-50%);
    background: var(--clay-deep);
    color: var(--birch-white);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    white-space: nowrap;
    z-index: 1;
  }

  .card__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    min-height: 4.75rem; /* equal title band across cards */
    margin-bottom: var(--space-3);
  }
  .card__icon {
    color: var(--hot-coal-bright);
    flex-shrink: 0;
  }
  .card--featured .card__icon { color: var(--ice-deep); }
  .card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--forest-deep);
    margin: 0;
    text-wrap: balance;
  }

  .card__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
    margin-bottom: 0.35rem;
  }
  .card__amount {
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 1.4rem + 0.8vw, 2.1rem);
    font-weight: var(--weight-bold);
    color: var(--forest-deep);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }
  .card__cadence {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    white-space: nowrap;
  }
  .card__duration,
  .card__sessions {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.02em;
    line-height: 1.35;
    min-height: 2.1em; /* two lines max, keeps feature lists aligned */
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .card--featured .card__duration,
  .card--featured .card__sessions { color: var(--ice-deep); }

  .card__list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }
  .card__list li {
    position: relative;
    padding-left: 1.35rem;
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: 1.4;
  }
  .card__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.05em;
    color: #7a9a6e;
    font-weight: var(--weight-bold);
  }

  .card__note {
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    font-style: italic;
    margin: 0 0 var(--space-3);
  }

  .card__footer {
    margin-top: auto;
    padding-top: var(--space-1);
  }
  /* Reach into CTAButton child root (scoped styles don't otherwise apply) */
  .card__footer :global(.card__cta),
  .card :global(.card__cta) {
    width: 100%;
    display: inline-flex;
    justify-content: center;
  }

  /* ---- good to know policies ---------------------------------------- */
  .policies {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .policies li {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--clay-terracotta);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
  }
  .policies__label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--hot-coal-bright);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-1);
  }

  .need-help {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .block-head h2 { color: var(--forest-deep); }
  .need-help a { font-weight: var(--weight-semibold); }

  /* ---- responsive --------------------------------------------------- */
  @media (max-width: 1100px) {
    .cards--tiers { grid-template-columns: repeat(2, 1fr); gap: var(--space-4); }
    .card__header { min-height: 4.25rem; }
  }
  @media (max-width: 600px) {
    .cards--walkin,
    .cards--tiers { grid-template-columns: 1fr; }
    .card__header { min-height: 0; }
  }
</style>
