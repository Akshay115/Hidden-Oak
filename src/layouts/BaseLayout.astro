---
/**
 * BaseLayout — HTML shell for every page.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
}

const {
  title,
  description = 'Hidden Oak — a traditional Russian banya in Arambol, Goa. Wood-fired steam, cold plunge, and quiet among the palms. Sessions from ₹500.',
  ogImage = '/images/og-default.svg',
  ogType = 'website',
} = Astro.props;

const SITE = 'https://hidden-oak.pages.dev';
const fullTitle = title === 'Hidden Oak' ? 'Hidden Oak · Russian Banya in Arambol, Goa' : `${title} · Hidden Oak`;
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImageUrl = new URL(ogImage, SITE).href;

const businessJsonLd = {
  '@context': 'https://schema.org',
  '@type': ['HealthAndBeautyBusiness', 'LocalBusiness'],
  '@id': `${SITE}/#business`,
  name: 'Hidden Oak',
  description:
    'A traditional Russian banya in Arambol, Goa. Wood-fired steam, cold plunge (ice bath), and venik ritual.',
  image: ogImageUrl,
  logo: new URL('/favicon.svg', SITE).href,
  url: SITE,
  telephone: '+919818083992',
  email: 'thehiddenoak@gmail.com',
  priceRange: '₹₹',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'H. No. 613/2, Madhalawada',
    addressLocality: 'Arambol',
    addressRegion: 'Goa',
    postalCode: '403524',
    addressCountry: 'IN',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 15.688385,
    longitude: 73.7053839,
  },
  hasMap: 'https://maps.app.goo.gl/HTjXm77Z5ggcumkR7',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '18:00',
      closes: '00:00',
    },
  ],
  sameAs: [],
  makesOffer: [
    { '@type': 'Offer', name: 'Banya Session (without ice bath)', price: '500', priceCurrency: 'INR' },
    { '@type': 'Offer', name: 'Banya Session (with ice bath)', price: '1000', priceCurrency: 'INR' },
    { '@type': 'Offer', name: 'Steam Only Membership', price: '3500', priceCurrency: 'INR' },
    { '@type': 'Offer', name: 'Full Reset Membership', price: '7000', priceCurrency: 'INR' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1e1510" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Hidden Oak" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(businessJsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      (() => {
        const reveals = document.querySelectorAll('[data-reveal]');
        if (reveals.length === 0) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          reveals.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
        );

        reveals.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -100px;
    z-index: var(--z-overlay);
    background: var(--birch-white);
    color: var(--color-bg);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    transition: top var(--duration-fast) var(--ease-soft);
  }
  .skip-link:focus {
    top: var(--space-4);
    color: var(--color-bg);
  }
</style>
