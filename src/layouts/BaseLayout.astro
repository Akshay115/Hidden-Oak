---
/**
 * BaseLayout — the HTML shell shared by every page.
 * Pulls in global design tokens, the sticky Header, and the Footer.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Hidden Oak — a traditional Russian banya. Wood, steam, and quiet, hidden among the oaks.',
} = Astro.props;

const fullTitle = title === 'Hidden Oak' ? title : `${title} · Hidden Oak`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts: Fraunces (warm display serif) + Manrope (humanist sans body).
         Preconnect first for a faster handshake, then load only the weights
         and axes actually used. Fraunces is variable (opsz, wght, SOFT). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&display=swap"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -100px;
    z-index: var(--z-overlay);
    background: var(--color-cream);
    color: var(--color-bg);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    transition: top var(--transition-fast);
  }
  .skip-link:focus {
    top: var(--space-4);
    color: var(--color-bg);
  }
</style>
