# ============================================================================
# Hidden Oak — Environment Variables
# ============================================================================
# Copy this file to `.env` for local development with `astro dev`.
#
# For PRODUCTION: set these in the Cloudflare Pages dashboard, NOT in a .env
# file that gets committed. Dashboard → your Pages project → Settings →
# Environment variables. Add to both "Production" and "Preview".
#
# IMPORTANT: BREVO_API_KEY is a SECRET — never commit it. Set it via:
#   Dashboard → Settings → Environment variables → Encrypt
# or via CLI:
#   npx wrangler pages secret put BREVO_API_KEY --project-name hidden-oak

# ---- Astro / Public site config (safe to expose to client) ------------------
PUBLIC_SITE_URL=https://hidden-oak.pages.dev

# ---- Cal.com booking embed (client-side, safe to expose) --------------------
# Your Cal.com username/event-slug. Embedded on /book.
# Find this at cal.com/dashboard/event-types
PUBLIC_CAL_LINK=hidden-oak/banya-session

# ---- Brevo CRM + Email (SERVER-SIDE ONLY — set in Cloudflare dashboard) -----
# Required for the contact form (functions/api/contact.ts) to work.
# Get these from Brevo: Settings → SMTP & API → API Keys

# SECRET — do NOT commit. Set via Cloudflare dashboard or:
#   npx wrangler pages secret put BREVO_API_KEY
BREVO_API_KEY=xkeysib-your-api-key-here

# Contact list to add enquirers to (optional). Brevo → Contacts → Lists → ID in URL.
BREVO_LIST_ID=

# Where notification emails are sent. Defaults to thehiddenoak@gmail.com.
CONTACT_EMAIL=thehiddenoak@gmail.com
